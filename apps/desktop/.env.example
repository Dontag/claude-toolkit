# Supabase backend for the Galaxy (Phase 2). Copy to .env and fill in from
# your Supabase project → Settings → API. The anon key is public by design —
# every access is enforced by row-level security.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Feature flags — leave these off if you don't want the extra functionality.
# In-app notifications (grant/request/proposal alerts). Default: true.
VITE_ENABLE_NOTIFICATIONS=true
# Email notifications. Requires the notify-email edge function + an email
# provider (Resend/SMTP). Keep false until you set that up. Default: false.
VITE_ENABLE_EMAIL=false
