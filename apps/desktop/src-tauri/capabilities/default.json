{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:tray:default",
    "opener:default",
    "dialog:default",
    "store:default",
    "notification:default",
    "updater:default",
    "process:allow-restart",
    "deep-link:default",
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-stat",
    "fs:allow-watch",
    "fs:allow-unwatch",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/.claude" },
        { "path": "$HOME/.claude/**" }
      ]
    }
  ]
}
