---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Claude Galaxy — a living 3D skill tree for your Claude Code setup." } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const nav = [
  { href: `${base}/`, label: "Home" },
  { href: `${base}/download`, label: "Download" },
  { href: `${base}/toolkit`, label: "Toolkit" },
  { href: `${base}/changelog`, label: "Changelog" },
  { href: `${base}/dashboard/`, label: "Web demo ↗" },
];
const path = Astro.url.pathname;
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/logo.svg`} />
  <title>{title}</title>
  <style is:global>
    :root{
      --bg0:#05070f; --bg1:#0b0f22; --bg2:#141a33;
      --text:#e7e9f4; --muted:#9aa3c7; --border:rgba(151,161,204,.16);
      --glass:rgba(20,26,51,.55); --brand:#8f83ff; --brand2:#7ce7f5;
      --skill:#ff6b7a; --agent:#ffb057; --hook:#a78bfa; --command:#38d3e8; --success:#34d399;
    }
    *{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      color:var(--text);font:16px/1.6 Inter,system-ui,-apple-system,"Segoe UI",sans-serif;
      background:
        radial-gradient(60% 45% at 18% 12%,rgba(122,60,240,.20) 0%,transparent 70%),
        radial-gradient(50% 40% at 85% 30%,rgba(217,75,208,.12) 0%,transparent 70%),
        radial-gradient(55% 50% at 60% 90%,rgba(46,110,224,.10) 0%,transparent 70%),
        radial-gradient(120% 90% at 50% 0%,var(--bg1) 0%,#05030f 60%,var(--bg0) 100%);
      background-attachment:fixed;min-height:100vh;
    }
    a{color:var(--brand2);text-decoration:none}
    a:hover{text-decoration:underline}
    .wrap{max-width:1040px;margin:0 auto;padding:0 24px}
    /* floating glowing capsule nav — matches the landing page */
    header.site{position:fixed;top:14px;left:50%;transform:translateX(-50%);z-index:10;
      width:max-content;max-width:calc(100vw - 20px);border-radius:999px;
      border:1px solid rgba(143,131,255,.4);background:rgba(8,10,25,.55);backdrop-filter:blur(14px);
      box-shadow:0 0 26px rgba(143,131,255,.22),inset 0 0 20px rgba(122,60,240,.12);
      animation:nav-glow 4.5s ease-in-out infinite}
    header.site .wrap{display:flex;align-items:center;gap:14px;padding:10px 12px 10px 22px;max-width:none}
    .logo{font-weight:700;letter-spacing:-.02em;color:var(--text);font-size:16px;white-space:nowrap}
    .logo:hover{text-decoration:none}
    nav.main{display:flex;gap:2px;margin-left:auto;flex-wrap:wrap;justify-content:flex-end}
    nav.main a{color:var(--muted);font-size:13px;padding:6px 12px;border-radius:99px;transition:all .15s;white-space:nowrap}
    nav.main a:hover{color:var(--text);background:rgba(143,131,255,.16);text-decoration:none}
    nav.main a.active{color:var(--text);background:rgba(143,131,255,.22)}
    @keyframes nav-glow{0%,100%{box-shadow:0 0 20px rgba(143,131,255,.2),inset 0 0 20px rgba(122,60,240,.1)}
      50%{box-shadow:0 0 38px rgba(124,231,245,.3),inset 0 0 24px rgba(122,60,240,.18)}}
    main{padding:110px 0 80px}
    h1{font-size:clamp(28px,5vw,44px);letter-spacing:-.03em;line-height:1.15}
    h2{font-size:22px;letter-spacing:-.02em;margin:40px 0 14px}
    p.lead{color:var(--muted);font-size:18px;max-width:640px}
    .btn{display:inline-block;border:1px solid var(--border);background:var(--glass);color:var(--text);
      border-radius:12px;padding:11px 20px;font-size:14.5px;font-weight:600;transition:all .15s;cursor:pointer}
    .btn:hover{border-color:var(--brand);box-shadow:0 0 0 3px rgba(143,131,255,.18);text-decoration:none;transform:translateY(-1px)}
    .btn.primary{background:linear-gradient(135deg,var(--brand),#6f5cf0);border-color:transparent}
    .card{background:var(--glass);border:1px solid var(--border);border-radius:16px;padding:20px 22px}
    .grid{display:grid;gap:14px}
    .badge{display:inline-block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;
      padding:3px 9px;border-radius:99px;border:1px solid var(--border)}
    footer.site{padding:0 0 26px;color:var(--muted);font-size:13px}
    footer.site::before{content:"";display:block;height:1px;margin-bottom:26px;
      background:linear-gradient(90deg,transparent,rgba(143,131,255,.55),rgba(124,231,245,.45),transparent)}
    footer.site .wrap{display:flex;gap:12px;flex-wrap:wrap;justify-content:space-between}
    .stars{position:fixed;inset:0;z-index:-1;pointer-events:none;opacity:.6;
      background-image:
        radial-gradient(1px 1px at 12% 22%,#fff8 0,transparent 100%),
        radial-gradient(1px 1px at 68% 12%,#fff6 0,transparent 100%),
        radial-gradient(1.5px 1.5px at 84% 42%,#b4aaff88 0,transparent 100%),
        radial-gradient(1px 1px at 32% 66%,#fff5 0,transparent 100%),
        radial-gradient(1.5px 1.5px at 52% 88%,#7ce7f588 0,transparent 100%),
        radial-gradient(1px 1px at 92% 78%,#fff7 0,transparent 100%),
        radial-gradient(2px 2px at 44% 34%,#d94bd066 0,transparent 100%),
        radial-gradient(1px 1px at 22% 48%,#fff6 0,transparent 100%),
        radial-gradient(1.5px 1.5px at 76% 64%,#8f83ff77 0,transparent 100%),
        radial-gradient(1px 1px at 8% 92%,#fff5 0,transparent 100%);
      animation:twinkle 6s ease-in-out infinite}
    @keyframes twinkle{0%,100%{opacity:.6}50%{opacity:.4}}
    @media (prefers-reduced-motion: reduce){header.site,.stars{animation:none}}
    @media (max-width:640px){ header.site .wrap{padding:8px 10px 8px 16px} nav.main a{padding:5px 9px} }
  </style>
</head>
<body>
  <div class="stars"></div>
  <header class="site">
    <div class="wrap">
      <a class="logo" href={`${base}/`}>🌳 Claude Galaxy</a>
      <nav class="main">
        {nav.map((n) => <a href={n.href} class={path === n.href || path === `${n.href}/` ? "active" : ""}>{n.label}</a>)}
      </nav>
    </div>
  </header>
  <main class="wrap">
    <slot />
  </main>
  <footer class="site">
    <div class="wrap">
      <span>© 2026 Claude Galaxy · Crafted by Nishad Patil</span>
      <span>Open source · <a href="https://github.com/Dontag/claude-toolkit">GitHub</a> · Built with Claude Code</span>
    </div>
  </footer>
</body>
</html>
