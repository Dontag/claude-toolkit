---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Claude Galaxy — a living 3D skill tree for your Claude Code setup." } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const path = Astro.url.pathname;
// same link set + order as the landing nav so the header is identical everywhere
const links = [
  { href: `${base}/toolkit`, label: "Toolkit" },
  { href: `${base}/changelog`, label: "Changelog" },
];
const isActive = (href: string) => path === href || path === `${href}/`;
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#05070f" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/logo.svg`} />
  <title>{title}</title>
  <style is:global>
    :root{
      --bg0:#05070f; --bg1:#0b0f22; --bg2:#141a33;
      --text:#e7e9f4; --muted:#9aa3c7; --border:rgba(151,161,204,.16);
      --glass:rgba(20,26,51,.55); --brand:#8f83ff; --brand2:#7ce7f5;
      --skill:#ff6b7a; --agent:#ffb057; --hook:#a78bfa; --command:#38d3e8; --success:#34d399;
    }
    *{margin:0;padding:0;box-sizing:border-box}
    /* html bg matches the page so mobile browser chrome + overscroll bounce
       stay dark instead of flashing white */
    html{scroll-behavior:smooth;background:var(--bg0)}
    body{
      color:var(--text);font:16px/1.6 Inter,system-ui,-apple-system,"Segoe UI",sans-serif;
      background:
        radial-gradient(60% 45% at 18% 12%,rgba(122,60,240,.20) 0%,transparent 70%),
        radial-gradient(50% 40% at 85% 30%,rgba(217,75,208,.12) 0%,transparent 70%),
        radial-gradient(55% 50% at 60% 90%,rgba(46,110,224,.10) 0%,transparent 70%),
        radial-gradient(120% 90% at 50% 0%,var(--bg1) 0%,#05030f 60%,var(--bg0) 100%);
      background-attachment:fixed;min-height:100vh;
    }
    a{color:var(--brand2);text-decoration:none}
    a:hover{text-decoration:underline}
    .wrap{max-width:1040px;margin:0 auto;padding:0 24px}
    /* floating glowing capsule nav — identical to the landing page */
    header.site{position:fixed;top:16px;left:50%;transform:translateX(-50%);z-index:10;
      width:max-content;max-width:calc(100vw - 20px);border-radius:999px;
      border:1px solid rgba(143,131,255,.35);background:rgba(8,10,25,.6);backdrop-filter:blur(16px) saturate(1.2);
      box-shadow:0 8px 40px rgba(5,3,15,.6),0 0 26px rgba(143,131,255,.18),inset 0 1px 0 rgba(255,255,255,.06)}
    header.site::before{content:"";position:absolute;inset:-2px;border-radius:999px;pointer-events:none;z-index:-1;
      background:linear-gradient(100deg,rgba(143,131,255,.4),rgba(217,75,208,.28),rgba(124,231,245,.4));
      filter:blur(10px);opacity:.4}
    header.site::after{content:"";position:absolute;inset:0;border-radius:999px;pointer-events:none;padding:1px;
      background:linear-gradient(100deg,rgba(143,131,255,.7),rgba(217,75,208,.5),rgba(124,231,245,.7));
      -webkit-mask:linear-gradient(#fff 0 0) padding-box,linear-gradient(#fff 0 0);
      -webkit-mask-composite:xor;mask-composite:exclude}
    header.site .wrap{display:flex;align-items:center;gap:10px;padding:8px 10px 8px 16px;max-width:none}
    /* on subpages the logo gently pulses as a "click to go home" cue */
    .logo{display:flex;align-items:center;gap:8px;font-weight:800;letter-spacing:-.02em;color:var(--text);font-size:16px;white-space:nowrap;padding-right:4px;
      animation:logo-hint 2.6s ease-in-out infinite}
    .logo img{width:26px;height:26px;filter:drop-shadow(0 0 8px rgba(143,131,255,.6));animation:logo-mark 2.6s ease-in-out infinite}
    .logo:hover{text-decoration:none;animation:none}
    .logo:hover img{animation:none;filter:drop-shadow(0 0 14px rgba(124,231,245,.95))}
    @keyframes logo-hint{0%,100%{opacity:.82}50%{opacity:1}}
    @keyframes logo-mark{0%,100%{filter:drop-shadow(0 0 6px rgba(143,131,255,.5)) brightness(1);transform:scale(1)}
      50%{filter:drop-shadow(0 0 15px rgba(124,231,245,.9)) brightness(1.15);transform:scale(1.08)}}
    nav.main{display:flex;gap:2px;margin-left:auto;align-items:center}
    nav.main a{position:relative;color:#aab2d4;font-size:13px;font-weight:500;padding:7px 13px;border-radius:99px;transition:.18s;white-space:nowrap}
    nav.main a::after{content:"";position:absolute;left:13px;right:13px;bottom:4px;height:1.5px;border-radius:2px;
      background:linear-gradient(90deg,#8f83ff,#7ce7f5);transform:scaleX(0);transform-origin:left;transition:transform .22s}
    nav.main a:hover{color:#fff;text-decoration:none}
    nav.main a:hover::after{transform:scaleX(1)}
    nav.main a.active{color:#fff}
    nav.main a.active::after{transform:scaleX(1)}
    nav.main a.cta{color:#fff;background:linear-gradient(120deg,#8f83ff,#7a3cf0 60%,#d94bd0);font-weight:700;box-shadow:0 4px 18px rgba(122,60,240,.4)}
    nav.main a.cta::after{display:none}
    nav.main a.cta:hover{filter:brightness(1.1);transform:translateY(-1px)}
    @keyframes halo-spin{to{transform:rotate(360deg)}}
    /* vertical padding lives on <main>; horizontal on the inner .wrap so the
       two never collide (a .wrap directly on main would zero the top pad and
       the content would slide under the fixed nav) */
    main{padding:120px 0 90px}
    h1{position:relative;font-size:clamp(30px,5vw,48px);letter-spacing:-.03em;line-height:1.12;font-weight:800;padding-bottom:14px;
      background:linear-gradient(120deg,#fff 20%,#c9c3ff 60%,#7ce7f5);-webkit-background-clip:text;background-clip:text;color:transparent}
    h1::after{content:"";position:absolute;left:2px;bottom:0;width:58px;height:3px;border-radius:3px;
      background:linear-gradient(90deg,var(--brand),var(--brand2))}
    h2{font-size:clamp(20px,2.4vw,26px);letter-spacing:-.02em;margin:48px 0 18px;font-weight:700}
    p.lead{color:var(--muted);font-size:clamp(15px,2vw,18px);max-width:660px;margin-top:14px}
    .btn{display:inline-block;border:1px solid var(--border);background:var(--glass);color:var(--text);
      border-radius:12px;padding:11px 20px;font-size:14.5px;font-weight:600;transition:all .18s;cursor:pointer}
    .btn:hover{border-color:var(--brand);box-shadow:0 8px 26px rgba(143,131,255,.28);text-decoration:none;transform:translateY(-2px)}
    .btn.primary{background:linear-gradient(135deg,var(--brand),#6f5cf0);border-color:transparent}
    .card{position:relative;background:linear-gradient(160deg,rgba(20,26,51,.6),rgba(8,10,22,.7));
      border:1px solid var(--border);border-radius:16px;padding:20px 22px;overflow:hidden;
      transition:transform .28s cubic-bezier(.16,1,.3,1),box-shadow .28s,border-color .28s}
    .card::before{content:"";position:absolute;left:0;right:0;top:0;height:2px;opacity:.7;
      background:linear-gradient(90deg,transparent,var(--brand),var(--brand2),transparent)}
    .card:hover{transform:translateY(-4px);border-color:rgba(143,131,255,.4);box-shadow:0 20px 50px rgba(122,60,240,.25)}
    .grid{display:grid;gap:16px}
    .badge{display:inline-block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;
      padding:3px 9px;border-radius:99px;border:1px solid var(--border)}
    footer.site{padding:0 0 26px;color:var(--muted);font-size:13px}
    footer.site::before{content:"";display:block;height:1px;margin-bottom:26px;
      background:linear-gradient(90deg,transparent,rgba(143,131,255,.55),rgba(124,231,245,.45),transparent)}
    footer.site .wrap{display:flex;gap:12px;flex-wrap:wrap;justify-content:space-between}
    @media (max-width:640px){footer.site .wrap{flex-direction:column;gap:8px;text-align:center;justify-content:center;align-items:center}}
    .stars{position:fixed;inset:0;z-index:-1;pointer-events:none;opacity:.6;
      background-image:
        radial-gradient(1px 1px at 12% 22%,#fff8 0,transparent 100%),
        radial-gradient(1px 1px at 68% 12%,#fff6 0,transparent 100%),
        radial-gradient(1.5px 1.5px at 84% 42%,#b4aaff88 0,transparent 100%),
        radial-gradient(1px 1px at 32% 66%,#fff5 0,transparent 100%),
        radial-gradient(1.5px 1.5px at 52% 88%,#7ce7f588 0,transparent 100%),
        radial-gradient(1px 1px at 92% 78%,#fff7 0,transparent 100%),
        radial-gradient(2px 2px at 44% 34%,#d94bd066 0,transparent 100%),
        radial-gradient(1px 1px at 22% 48%,#fff6 0,transparent 100%),
        radial-gradient(1.5px 1.5px at 76% 64%,#8f83ff77 0,transparent 100%),
        radial-gradient(1px 1px at 8% 92%,#fff5 0,transparent 100%);
      animation:twinkle 6s ease-in-out infinite}
    @keyframes twinkle{0%,100%{opacity:.6}50%{opacity:.4}}
    @media (prefers-reduced-motion: reduce){header.site,.stars,.logo,.logo img{animation:none}}
    @media (max-width:560px){
      header.site .wrap{gap:6px;padding:7px 8px 7px 12px}
      .logo img{width:22px;height:22px}
      .logo{font-size:13.5px}
      nav.main a{font-size:12px;padding:6px 9px}
      nav.main a.nav-github{display:none}
    }
  </style>
</head>
<body>
  <div class="stars"></div>
  <header class="site">
    <div class="wrap">
      <a class="logo" href={`${base}/`}><img src={`${base}/logo.svg`} alt="" />Claude&nbsp;Galaxy</a>
      <nav class="main">
        {links.map((n) => <a href={n.href} class={isActive(n.href) ? "active" : ""}>{n.label}</a>)}
        <a class="nav-github" href="https://github.com/Dontag/claude-toolkit" target="_blank" rel="noopener noreferrer" aria-label="GitHub">GitHub ↗</a>
        <a href={`${base}/download`} class:list={["cta", { active: isActive(`${base}/download`) }]}>Download</a>
      </nav>
    </div>
  </header>
  <main>
    <div class="wrap">
      <slot />
    </div>
  </main>
  <footer class="site">
    <div class="wrap">
      <span>© 2026 Claude Galaxy · Crafted by Nishad Patil</span>
      <span>Open source · <a href="https://github.com/Dontag/claude-toolkit" target="_blank" rel="noopener noreferrer">GitHub</a> · Built with Claude Code</span>
    </div>
  </footer>
</body>
</html>
