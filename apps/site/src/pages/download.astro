---
import Base from "../layouts/Base.astro";
import { loadReleases } from "../lib/data";

const releases = loadReleases();
const latest = releases[0] ?? null;

function assetFor(patterns: RegExp[]) {
  if (!latest) return null;
  for (const p of patterns) {
    const a = latest.assets.find((a) => p.test(a.name));
    if (a) return a;
  }
  return null;
}
const mb = (n: number) => (n / 1048576).toFixed(1) + " MB";
const oses = [
  { name: "Windows", emoji: "🪟", asset: assetFor([/\.msi$/i, /setup.*\.exe$/i, /\.exe$/i]), note: "Windows 10/11 · .msi installer" },
  { name: "macOS", emoji: "🍎", asset: assetFor([/aarch64.*\.dmg$/i, /\.dmg$/i]), note: "Apple Silicon & Intel · .dmg" },
  { name: "Linux", emoji: "🐧", asset: assetFor([/\.AppImage$/i, /\.deb$/i]), note: ".AppImage / .deb" },
];
---
<Base title="Download — Claude Toolkit">
  <h1>Download</h1>
  {latest ? (
    <p class="lead" style="margin-top:10px">
      Latest release: <strong>v{latest.version}</strong> · {new Date(latest.publishedAt).toISOString().slice(0, 10)}
    </p>
  ) : (
    <p class="lead" style="margin-top:10px">
      The desktop app hasn't shipped its first release yet — it's in active development.
      Meanwhile, the <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/dashboard/`}>web demo</a> shows the tree in your browser.
    </p>
  )}

  <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(250px,1fr));margin-top:28px">
    {oses.map((os) => (
      <div class="card" style="text-align:center;padding:28px 22px">
        <div style="font-size:40px">{os.emoji}</div>
        <h2 style="margin:10px 0 4px;font-size:19px">{os.name}</h2>
        <div style="color:var(--muted);font-size:13px;margin-bottom:16px">{os.note}</div>
        {os.asset ? (
          <a class="btn primary" href={os.asset.url}>⬇ Download ({mb(os.asset.size)})</a>
        ) : (
          <span class="btn" style="opacity:.5;cursor:default">Coming soon</span>
        )}
      </div>
    ))}
  </div>

  <h2>Heads-up: unsigned builds (for now)</h2>
  <div class="card" style="color:var(--muted);font-size:14.5px;line-height:1.7">
    Early builds aren't code-signed yet, so your OS will warn you on first launch:
    <ul style="margin:10px 0 0 20px">
      <li><strong>Windows SmartScreen</strong> — click <em>More info → Run anyway</em>.</li>
      <li><strong>macOS Gatekeeper</strong> — right-click the app → <em>Open</em> → <em>Open</em> (needed once).</li>
      <li><strong>Linux</strong> — <code>chmod +x</code> the AppImage, then run.</li>
    </ul>
    Every release is built in public by <a href="https://github.com/Dontag/claude-toolkit/actions">GitHub Actions</a> straight from the source you can read.
    The app auto-updates itself after installation.
  </div>

  {releases.length > 1 && (
    <>
      <h2>Previous releases</h2>
      <div class="grid">
        {releases.slice(1, 6).map((r) => (
          <div class="card" style="display:flex;justify-content:space-between;align-items:center">
            <span>v{r.version}</span>
            <span style="color:var(--muted);font-size:13px">{new Date(r.publishedAt).toISOString().slice(0, 10)}</span>
          </div>
        ))}
      </div>
    </>
  )}
</Base>
