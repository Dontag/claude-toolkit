  <div id="toast"></div>
  <script id="dl-data" type="application/json" set:html={JSON.stringify(downloads)}></script>

  <script>
    import * as THREE from "three";

    /* ── toast ── */
    const toastEl = document.getElementById("toast")!;
    let toastT: ReturnType<typeof setTimeout>;
    function toast(msg: string) {
      toastEl.textContent = msg;
      toastEl.classList.add("show");
      clearTimeout(toastT);
      toastT = setTimeout(() => toastEl.classList.remove("show"), 2800);
    }
    /* ── platform-aware desktop download ──
       detect the visitor's OS, relabel the buttons, and serve the matching
       installer from the latest GitHub release; fall back to the /download
       page (all platforms + coming-soon state) when no asset is available. */
    interface Downloads { version: string | null; windows: string | null; mac: string | null; linux: string | null; page: string }
    const dl = JSON.parse(document.getElementById("dl-data")!.textContent!) as Downloads;

    function detectOS(): "windows" | "mac" | "linux" | null {
      const nav = navigator as Navigator & { userAgentData?: { platform?: string } };
      const s = (nav.userAgentData?.platform || navigator.platform || navigator.userAgent).toLowerCase();
      // phones/tablets have no desktop build → route them to the download page
      if (/android|iphone|ipad|ipod/.test(navigator.userAgent.toLowerCase())) return null;
      if (s.includes("win")) return "windows";
      if (s.includes("mac")) return "mac";
      if (s.includes("linux")) return "linux";
      return null;
    }
    const OS_LABEL = { windows: "Windows", mac: "macOS", linux: "Linux" } as const;
    const os = detectOS();
    const assetUrl = os ? dl[os] : null;

    for (const id of ["downloadBtn", "downloadBtn2"]) {
      const btn = document.getElementById(id);
      if (!btn) continue;
      if (os) btn.textContent = `⬇ Download for ${OS_LABEL[os]}`;
      btn.addEventListener("click", () => {
        if (assetUrl) {
          toast(`⬇ Downloading Claude Galaxy${dl.version ? " v" + dl.version : ""} for ${OS_LABEL[os!]}…`);
          location.href = assetUrl;
        } else {
          // no build for this OS yet (or unknown OS) → the full download page
          location.href = dl.page;
        }
      });
    }

    /* ── custom planet cursor (fine-pointer only) ── */
    const cur = document.getElementById("cursor");
    if (cur && matchMedia("(pointer:fine)").matches) {
      document.body.classList.add("has-cursor");
      let cx = innerWidth / 2, cy = innerHeight / 2, tx = cx, ty = cy;
      addEventListener("pointermove", (e) => { tx = e.clientX; ty = e.clientY; }, { passive: true });
      addEventListener("pointerdown", () => { cur.classList.remove("down"); void cur.offsetWidth; cur.classList.add("down"); });
      addEventListener("pointerup", () => cur.classList.remove("down"));
      const hoverSel = "a,button,input,textarea,.tilt,.stat";
      addEventListener("pointerover", (e) => { if ((e.target as Element)?.closest?.(hoverSel)) cur.classList.add("hover"); });
      addEventListener("pointerout", (e) => { if ((e.target as Element)?.closest?.(hoverSel)) cur.classList.remove("hover"); });
      (function follow() {
        cx += (tx - cx) * 0.28; cy += (ty - cy) * 0.28;
        cur.style.transform = `translate(${cx}px,${cy}px)`;
        requestAnimationFrame(follow);
      })();
    }

    /* ── scroll reveals ── */
    const io = new IntersectionObserver(
      (entries) => entries.forEach((e) => e.isIntersecting && e.target.classList.add("in")),
      { threshold: 0.18 },
    );
    document.querySelectorAll(".reveal").forEach((el) => io.observe(el));

    /* ── count-up stats ── */
    const countIO = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        const el = e.target as HTMLElement;
        const target = +(el.dataset.count || "0");
        const start = performance.now();
        const tick = (now: number) => {
          const k = Math.min(1, (now - start) / 900);
          el.textContent = Math.round(target * (1 - Math.pow(1 - k, 3))).toString();
          if (k < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
        countIO.unobserve(el);
      }
    }, { threshold: 0.6 });
    document.querySelectorAll<HTMLElement>(".stat b[data-count]").forEach((el) => countIO.observe(el));

    /* ── card tilt ── */
    document.querySelectorAll<HTMLElement>(".tilt").forEach((card) => {
      card.addEventListener("mousemove", (e) => {
        const r = card.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top) / r.height - 0.5;
        card.style.transform = `rotateY(${x * 10}deg) rotateX(${-y * 10}deg) translateZ(8px)`;
      });
      card.addEventListener("mouseleave", () => (card.style.transform = ""));
    });

    /* ── parallax layers ── */
    const parallaxEls = [...document.querySelectorAll<HTMLElement>("[data-parallax]")];
    addEventListener("scroll", () => {
      const y = scrollY;
      for (const el of parallaxEls) {
        el.style.transform = `translateY(${y * -parseFloat(el.dataset.parallax!)}px)`;
      }
    }, { passive: true });

    /* ── 3D nebula sky ── */
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const canvas = document.getElementById("sky") as HTMLCanvasElement;
    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
    renderer.setSize(innerWidth, innerHeight);
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(55, innerWidth / innerHeight, 0.1, 400);
    camera.position.z = 60;

    function softTex(): THREE.CanvasTexture {
      const c = document.createElement("canvas");
      c.width = c.height = 64;
      const x = c.getContext("2d")!;
      const g = x.createRadialGradient(32, 32, 0, 32, 32, 32);
      g.addColorStop(0, "rgba(255,255,255,.9)");
      g.addColorStop(0.35, "rgba(255,255,255,.32)");
      g.addColorStop(1, "rgba(255,255,255,0)");
      x.fillStyle = g;
      x.fillRect(0, 0, 64, 64);
      return new THREE.CanvasTexture(c);
    }
    function nebulaTex(seed: number): THREE.CanvasTexture {
      const S = 256, c = document.createElement("canvas");
      c.width = c.height = S;
      const x = c.getContext("2d")!;
      let s = seed;
      const rnd = () => ((s = (s * 16807) % 2147483647) - 1) / 2147483646;
      x.globalCompositeOperation = "lighter";
      // deeper, more saturated tints + a sharper mid stop so the cloud reads
      // as rich violet/magenta rather than a flat milky wash
      const tints = [[120,24,215],[185,30,150],[80,20,205],[168,44,225]];
      for (let i = 0; i < 42; i++) {
        const cx = rnd()*S, cy = rnd()*S, r = 20 + rnd()*80;
        const [rr,gg,bb] = tints[(rnd()*tints.length)|0];
        const a = 0.04 + rnd()*0.1;
        const g = x.createRadialGradient(cx,cy,0,cx,cy,r);
        g.addColorStop(0, `rgba(${rr},${gg},${bb},${a})`);
        g.addColorStop(0.45, `rgba(${rr},${gg},${bb},${a*0.35})`);
        g.addColorStop(1, "rgba(0,0,0,0)");
        x.fillStyle = g; x.beginPath(); x.arc(cx,cy,r,0,7); x.fill();
      }
      // a few bright hot cores for contrast/detail
      for (let i = 0; i < 6; i++) {
        const cx = rnd()*S, cy = rnd()*S, r = 5 + rnd()*12;
        const g = x.createRadialGradient(cx,cy,0,cx,cy,r);
        g.addColorStop(0, `rgba(240,214,255,${0.12+rnd()*0.14})`);
        g.addColorStop(1, "rgba(240,214,255,0)");
        x.fillStyle = g; x.beginPath(); x.arc(cx,cy,r,0,7); x.fill();
      }
      return new THREE.CanvasTexture(c);
    }

    const glow = softTex();
    // star layers (parallax depths) — denser now
    const starLayers: THREE.Points[] = [];
    for (const [count, spread, size, op] of [[1500, 170, 1.1, .9],[1000, 120, .8, .6],[600, 85, .6, .42]] as const) {
      const pos = new Float32Array(count * 3);
      const col = new Float32Array(count * 3);
      const palette = [0xffffff, 0x8f83ff, 0x7ce7f5, 0xd94bd0, 0xffb057];
      for (let i = 0; i < count; i++) {
        pos[i*3] = (Math.random()-0.5)*spread*2;
        pos[i*3+1] = (Math.random()-0.5)*spread*1.2;
        pos[i*3+2] = (Math.random()-0.5)*spread - 20;
        const c = new THREE.Color(palette[Math.random() < .7 ? 0 : 1 + ((Math.random()*4)|0)]);
        col[i*3]=c.r; col[i*3+1]=c.g; col[i*3+2]=c.b;
      }
      const g = new THREE.BufferGeometry();
      g.setAttribute("position", new THREE.BufferAttribute(pos, 3));
      g.setAttribute("color", new THREE.BufferAttribute(col, 3));
      const p = new THREE.Points(g, new THREE.PointsMaterial({ size, map: glow, vertexColors: true, transparent: true, opacity: op, depthWrite: false, blending: THREE.AdditiveBlending }));
      scene.add(p);
      starLayers.push(p);
    }
    // nebula billboards
    const nebulae: THREE.Sprite[] = [];
    const nTex = [nebulaTex(11), nebulaTex(22), nebulaTex(33)];
    const nCol = [0x9a3cff, 0xc93cc0, 0x6a2ce8, 0xe84ac0];
    for (let i = 0; i < 7; i++) {
      const sp = new THREE.Sprite(new THREE.SpriteMaterial({ map: nTex[i % 3], color: nCol[i % 4], transparent: true, opacity: .22, blending: THREE.AdditiveBlending, depthWrite: false, rotation: Math.random()*7 }));
      sp.position.set((Math.random()-.5)*220, (Math.random()-.5)*130, -40 - Math.random()*60);
      const s = 120 + Math.random()*120;
      sp.scale.set(s, s*.72, 1);
      scene.add(sp);
      nebulae.push(sp);
    }
    // drifting interstellar dust — fine motes filling the deep field
    const dustN = 1400;
    const dpos = new Float32Array(dustN * 3);
    const dcol = new Float32Array(dustN * 3);
    const dustTints = [new THREE.Color(0x8fb8ff), new THREE.Color(0xb8a1ff), new THREE.Color(0xffd9b0), new THREE.Color(0xff9ad8)];
    for (let i = 0; i < dustN; i++) {
      dpos[i*3] = (Math.random()-.5)*300;
      dpos[i*3+1] = (Math.random()-.5)*180;
      dpos[i*3+2] = -10 - Math.random()*160;
      const c = dustTints[(Math.random()*dustTints.length)|0];
      dcol[i*3]=c.r; dcol[i*3+1]=c.g; dcol[i*3+2]=c.b;
    }
    const dgeo = new THREE.BufferGeometry();
    dgeo.setAttribute("position", new THREE.BufferAttribute(dpos, 3));
    dgeo.setAttribute("color", new THREE.BufferAttribute(dcol, 3));
    const dust = new THREE.Points(dgeo, new THREE.PointsMaterial({ size:.34, map:glow, vertexColors:true, transparent:true, opacity:.28, depthWrite:false, blending:THREE.AdditiveBlending }));
    scene.add(dust);

    /* distant labelled solar systems — tiny star + orbiting planet + a name
       sprite, scattered far in the field so the galaxy feels inhabited */
    const SYS_NAMES = ["Kepler-9c","Vela","Cassia","Orion-B","Nyx","Lyra-4","Halcyon","Zephyr","Meridian","Astraeus","Caelum","Vesper"];
    // crisp, letter-spaced "star catalog" label: a small diamond marker + the
    // name in uppercase mono, rendered at 2x so it stays sharp when scaled
    function labelTex(text: string): { tex: THREE.CanvasTexture; asp: number } {
      const dpr = 2, fs = 30, pad = 8, ls = 4, markerW = 22;
      const upper = text.toUpperCase();
      const font = `500 ${fs}px ui-monospace, "SF Mono", Menlo, monospace`;
      const meas = document.createElement("canvas").getContext("2d")!;
      meas.font = font;
      let tw = 0; for (const ch of upper) tw += meas.measureText(ch).width + ls;
      const w = Math.ceil(markerW + tw) + pad*2, h = fs + pad*2;
      const c = document.createElement("canvas"); c.width = w*dpr; c.height = h*dpr;
      const x = c.getContext("2d")!; x.scale(dpr, dpr);
      x.font = font; x.textBaseline = "middle";
      const my = h/2;
      x.fillStyle = "rgba(124,231,245,.75)";
      x.beginPath(); x.moveTo(pad+6, my-5); x.lineTo(pad+11, my); x.lineTo(pad+6, my+5); x.lineTo(pad+1, my); x.closePath(); x.fill();
      x.fillStyle = "rgba(208,220,244,.92)";
      let tx = pad + markerW;
      for (const ch of upper) { x.fillText(ch, tx, my); tx += x.measureText(ch).width + ls; }
      const t = new THREE.CanvasTexture(c); t.minFilter = THREE.LinearFilter;
      return { tex: t, asp: w / h };
    }
    interface Sys { star: THREE.Sprite; planet: THREE.Sprite; label: THREE.Sprite; r: number; a: number; sp: number; cx: number; cy: number; cz: number }
    const systems: Sys[] = [];
    const usedNames = [...SYS_NAMES].sort(() => Math.random()-.5).slice(0, 6);
    for (const name of usedNames) {
      const cx = (Math.random()-.5)*260, cy = (Math.random()-.5)*150, cz = -70 - Math.random()*90;
      const hue = Math.random();
      const starCol = new THREE.Color().setHSL(.5 + hue*.25, .8, .7).getHex();
      const star = new THREE.Sprite(new THREE.SpriteMaterial({ map: glow, color: starCol, transparent:true, opacity:.95, blending:THREE.AdditiveBlending, depthWrite:false }));
      star.position.set(cx, cy, cz); const ss = 3 + Math.random()*3; star.scale.set(ss, ss, 1); scene.add(star);
      const planet = new THREE.Sprite(new THREE.SpriteMaterial({ map: glow, color: 0xcfe0ff, transparent:true, opacity:.8, blending:THREE.AdditiveBlending, depthWrite:false }));
      planet.scale.set(1.1, 1.1, 1); scene.add(planet);
      const lab = labelTex(name);
      const label = new THREE.Sprite(new THREE.SpriteMaterial({ map: lab.tex, transparent:true, opacity:.42, depthWrite:false }));
      const lh = 2.1; label.scale.set(lh*lab.asp, lh, 1); label.position.set(cx, cy - ss - 2.2, cz); scene.add(label);
      systems.push({ star, planet, label, r: 4 + Math.random()*4, a: Math.random()*7, sp: .15 + Math.random()*.3, cx, cy, cz });
    }

    /* planets — shaded sprite globes (one ringed) drifting at statement
       depths, so the tall scroll sections aren't empty space */
    function planetTex(tint: [number, number, number], ring: boolean, seed: number): THREE.CanvasTexture {
      const S = 256, c = document.createElement("canvas");
      c.width = c.height = S;
      const x = c.getContext("2d")!;
      let s = seed;
      const rnd = () => ((s = (s * 16807) % 2147483647) - 1) / 2147483646;
      const [r, g, b] = tint;
      // R kept small enough that a tilted ring (up to ~1.65 R) still fits
      // inside the texture — otherwise the ring clips at the sprite's edge
      const cx = S / 2, cy = S / 2, R = S * 0.26;
      // sphere shading: lit upper-left → deep shadow lower-right
      const grad = x.createRadialGradient(cx - R * 0.45, cy - R * 0.5, R * 0.1, cx, cy, R);
      grad.addColorStop(0, `rgba(${Math.min(255, r + 90)},${Math.min(255, g + 90)},${Math.min(255, b + 90)},1)`);
      grad.addColorStop(0.55, `rgba(${r},${g},${b},1)`);
      grad.addColorStop(1, `rgba(${(r * 0.25) | 0},${(g * 0.25) | 0},${(b * 0.25) | 0},1)`);
      x.fillStyle = grad;
      x.beginPath(); x.arc(cx, cy, R, 0, 7); x.fill();
      // faint latitude bands
      x.save();
      x.beginPath(); x.arc(cx, cy, R, 0, 7); x.clip();
      for (let i = 0; i < 5; i++) {
        x.fillStyle = `rgba(255,255,255,${0.04 + rnd() * 0.05})`;
        x.fillRect(cx - R, cy - R + rnd() * R * 2, R * 2, 2 + rnd() * 7);
      }
      x.restore();
      // atmosphere rim
      x.strokeStyle = `rgba(${Math.min(255, r + 70)},${Math.min(255, g + 70)},${Math.min(255, b + 70)},.5)`;
      x.lineWidth = 2.5;
      x.beginPath(); x.arc(cx, cy, R + 1.5, 0, 7); x.stroke();
      if (ring) {
        x.strokeStyle = `rgba(${Math.min(255, r + 60)},${Math.min(255, g + 60)},${Math.min(255, b + 60)},.55)`;
        x.lineWidth = 5;
        x.beginPath(); x.ellipse(cx, cy, R * 1.42, R * 0.44, -0.42, 0, 7); x.stroke();
        x.strokeStyle = `rgba(255,255,255,.22)`;
        x.lineWidth = 2;
        x.beginPath(); x.ellipse(cx, cy, R * 1.62, R * 0.5, -0.42, 0, 7); x.stroke();
      }
      return new THREE.CanvasTexture(c);
    }
    const planets: Array<{ m: THREE.Sprite; depth: number; bob: number }> = [];
    const planetDefs: Array<[[number, number, number], boolean, number, [number, number, number], number]> = [
      // [tint, ringed, size, position, seed] — sizes bumped ~1.3x to offset the
      // smaller R above so on-screen planets stay the same size
      [[122, 60, 240], false, 39, [-78, 14, -55], 5],
      [[46, 197, 255], true, 62, [72, -46, -80], 9],
      [[217, 75, 160], false, 26, [38, 64, -95], 13],
    ];
    for (const [tint, ring, size, [px, py, pz], seed] of planetDefs) {
      const m = new THREE.Sprite(new THREE.SpriteMaterial({ map: planetTex(tint, ring, seed), transparent: true, depthWrite: false }));
      m.position.set(px, py, pz);
      m.scale.set(size, size, 1);
      scene.add(m);
      planets.push({ m, depth: 0.4 + Math.random() * 0.5, bob: Math.random() * 7 });
    }
    /* asteroid stream — small tumbling rocks drifting across the deep field */
    function rockTex(seed: number): THREE.CanvasTexture {
      const S = 64, c = document.createElement("canvas");
      c.width = c.height = S;
      const x = c.getContext("2d")!;
      let s = seed;
      const rnd = () => ((s = (s * 16807) % 2147483647) - 1) / 2147483646;
      x.fillStyle = "rgba(140,132,120,1)";
      x.beginPath();
      for (let i = 0; i <= 9; i++) {
        const a = (i / 9) * Math.PI * 2;
        const r = S * (0.24 + rnd() * 0.14);
        const px = S / 2 + Math.cos(a) * r, py = S / 2 + Math.sin(a) * r;
        i ? x.lineTo(px, py) : x.moveTo(px, py);
      }
      x.closePath(); x.fill();
      x.fillStyle = "rgba(0,0,0,.35)";
      for (let i = 0; i < 5; i++) {
        x.beginPath(); x.arc(S * (0.3 + rnd() * 0.4), S * (0.3 + rnd() * 0.4), 2 + rnd() * 4, 0, 7); x.fill();
      }
      return new THREE.CanvasTexture(c);
    }
    const rocks: Array<{ m: THREE.Sprite; v: number; rs: number }> = [];
    for (let i = 0; i < 9; i++) {
      const m = new THREE.Sprite(new THREE.SpriteMaterial({ map: rockTex(31 + i * 7), transparent: true, opacity: 0.85, depthWrite: false, rotation: Math.random() * 7 }));
      m.position.set((Math.random() - 0.5) * 300, (Math.random() - 0.5) * 120, -30 - Math.random() * 70);
      const s = 1.2 + Math.random() * 2.4;
      m.scale.set(s, s, 1);
      scene.add(m);
      rocks.push({ m, v: 2 + Math.random() * 4, rs: (Math.random() - 0.5) * 0.6 });
    }

    // occasional comet
    interface Comet { m: THREE.Sprite; v: THREE.Vector3; life: number }
    let comet: Comet | null = null;
    let nextComet = performance.now() + 4000;
    function spawnComet(): Comet {
      const m = new THREE.Sprite(new THREE.SpriteMaterial({ map: glow, color: nCol[(Math.random()*4)|0], transparent: true, blending: THREE.AdditiveBlending, depthWrite: false }));
      m.scale.set(4, 4, 1);
      const side = Math.random() < .5 ? -1 : 1;
      m.position.set(side * 140, 30 + Math.random()*50, -30);
      scene.add(m);
      return { m, v: new THREE.Vector3(-side * (40 + Math.random()*25), -(12 + Math.random()*10), 0), life: 0 };
    }

    const mouse = { x: 0, y: 0 };
    addEventListener("pointermove", (e) => {
      mouse.x = (e.clientX / innerWidth) * 2 - 1;
      mouse.y = (e.clientY / innerHeight) * 2 - 1;
    });
    addEventListener("resize", () => {
      camera.aspect = innerWidth / innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(innerWidth, innerHeight);
    });

    const clock = new THREE.Clock();
    (function animate() {
      requestAnimationFrame(animate);
      const dt = Math.min(clock.getDelta(), .05);
      const t = clock.elapsedTime;
      const sy = scrollY * 0.02;
      // mouse + scroll parallax at different depths
      starLayers.forEach((p, i) => {
        const depth = (i + 1) / starLayers.length;
        p.position.x += ((-mouse.x * 8 * depth) - p.position.x) * .04;
        p.position.y += ((mouse.y * 5 * depth + sy * depth * 2) - p.position.y) * .04;
        p.rotation.z += dt * .004 * (i % 2 ? 1 : -1);
        (p.material as THREE.PointsMaterial).opacity = [.9,.6,.4][i] + Math.sin(t * (.5 + i*.2)) * .08;
      });
      nebulae.forEach((n, i) => {
        n.material.rotation += dt * .012 * (i % 2 ? 1 : -1);
        n.material.opacity = .2 + Math.sin(t * .2 + i) * .06;
        n.position.y += Math.sin(t * .1 + i * 2) * .01;
      });
      // dust drifts slowly and parallaxes with the pointer
      dust.rotation.z += dt * .004;
      dust.position.x += ((-mouse.x * 6) - dust.position.x) * .03;
      dust.position.y += ((mouse.y * 4 + sy * 3) - dust.position.y) * .03;
      // distant systems: planet orbits its star, star twinkles, label fades in/out
      for (const s of systems) {
        s.a += s.sp * dt;
        s.planet.position.set(s.cx + Math.cos(s.a) * s.r, s.cy + Math.sin(s.a) * s.r * .5, s.cz);
        (s.star.material as THREE.SpriteMaterial).opacity = .8 + Math.sin(t * 1.5 + s.cx) * .15;
        (s.label.material as THREE.SpriteMaterial).opacity = .4 + Math.sin(t * .4 + s.cy) * .18;
      }
      // planets bob gently and ride the scroll at their own depths
      planets.forEach((p, i) => {
        p.m.position.y += (Math.sin(t * 0.14 + p.bob) * 0.012);
        p.m.position.x += ((-mouse.x * 4 * p.depth) - (p.m.position.x - planetDefs[i]![3][0])) * 0.02;
      });
      // asteroids tumble slowly across the field, wrapping at the edges
      for (const r of rocks) {
        r.m.position.x += r.v * dt;
        r.m.material.rotation += r.rs * dt;
        if (r.m.position.x > 165) r.m.position.x = -165;
      }
      if (!reduced && performance.now() > nextComet && !comet) comet = spawnComet();
      if (comet) {
        comet.life += dt;
        comet.m.position.addScaledVector(comet.v, dt);
        comet.m.material.opacity = Math.max(0, 1 - comet.life / 4);
        if (comet.life > 4) {
          scene.remove(comet.m);
          comet = null;
          nextComet = performance.now() + 6000 + Math.random() * 14000;
        }
      }
      renderer.render(scene, camera);
    })();
  </script>
</body>
</html>
