---
// Cinematic parallax landing — 3D nebula hero, story scroll, founder, CTAs.
import { loadReleases } from "../lib/data";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Resolve the latest release's installer per OS so the hero "Download" button
// can serve the visitor's platform directly. Absent before the first release —
// the client then routes to the /download page (which shows the coming-soon state).
const latest = loadReleases()[0] ?? null;
const pick = (patterns: RegExp[]): string | null => {
  if (!latest) return null;
  for (const p of patterns) {
    const a = latest.assets.find((a) => p.test(a.name));
    if (a) return a.url;
  }
  return null;
};
const downloads = {
  version: latest?.version ?? null,
  windows: pick([/\.msi$/i, /setup\.exe$/i, /\.exe$/i]),
  mac: pick([/aarch64.*\.dmg$/i, /\.dmg$/i]),
  linux: pick([/\.AppImage$/i, /\.deb$/i]),
  page: `${base}/download`,
};
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Claude Galaxy — your Claude setup as a living 3D tree, and a shared galaxy of skills." />
  <link rel="icon" type="image/svg+xml" href={`${base}/logo.svg`} />
  <title>Claude Galaxy — a living galaxy for your Claude setup</title>
  <style>
    :root{
      --bg:#05030f; --text:#e7e9f4; --muted:#9aa3c7; --border:rgba(151,161,204,.16);
      --brand:#8f83ff; --brand2:#7ce7f5; --magenta:#d94bd0; --violet:#7a3cf0;
    }
    *{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:#e7e9f4;font:16px/1.6 Inter,system-ui,-apple-system,"Segoe UI",sans-serif;overflow-x:hidden}
    a{color:#7ce7f5;text-decoration:none}
    /* fixed 3D sky behind everything */
    #sky{position:fixed;inset:0;z-index:0}
    .veil{position:fixed;inset:0;z-index:1;pointer-events:none;
      background:radial-gradient(120% 80% at 50% 10%,transparent 30%,rgba(5,3,15,.55) 75%,rgba(5,3,15,.92) 100%)}
    /* nav — floating glowing capsule */
    nav{position:fixed;top:14px;left:50%;transform:translateX(-50%);z-index:20;display:flex;align-items:center;gap:14px;
      width:max-content;max-width:calc(100vw - 20px);padding:10px 12px 10px 22px;border-radius:999px;
      border:1px solid rgba(143,131,255,.4);background:rgba(8,10,25,.55);backdrop-filter:blur(14px);
      box-shadow:0 0 26px rgba(143,131,255,.22),inset 0 0 20px rgba(122,60,240,.12);
      animation:nav-glow 4.5s ease-in-out infinite}
    nav::before{content:"";position:absolute;inset:-1px;border-radius:999px;pointer-events:none;
      background:linear-gradient(100deg,rgba(143,131,255,.5),rgba(217,75,208,.35),rgba(124,231,245,.5)) border-box;
      -webkit-mask:linear-gradient(#fff 0 0) padding-box,linear-gradient(#fff 0 0);
      -webkit-mask-composite:xor;mask-composite:exclude;padding:1px;opacity:.7}
    nav .logo{font-weight:800;letter-spacing:-.02em;color:#e7e9f4;white-space:nowrap}
    nav .links{display:flex;gap:2px;flex-wrap:wrap;justify-content:flex-end}
    nav .links a{color:#9aa3c7;font-size:13px;padding:6px 12px;border-radius:99px;transition:.15s;white-space:nowrap}
    nav .links a:hover{color:#e7e9f4;background:rgba(143,131,255,.16)}
    @keyframes nav-glow{0%,100%{box-shadow:0 0 20px rgba(143,131,255,.2),inset 0 0 20px rgba(122,60,240,.1)}
      50%{box-shadow:0 0 38px rgba(124,231,245,.3),inset 0 0 24px rgba(122,60,240,.18)}}
    section{position:relative;z-index:2}
    .wrap{max-width:1080px;margin:0 auto;padding:0 28px}
    /* hero */
    .hero{min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center}
    .hero-inner{transform:translateZ(0)}
    .eyebrow{display:inline-block;font:600 11px/1 ui-monospace,monospace;letter-spacing:.22em;text-transform:uppercase;
      color:#7ce7f5;border:1px solid rgba(124,231,245,.35);padding:8px 14px;border-radius:99px;
      background:rgba(124,231,245,.06);animation:pulse-glow 3s ease-in-out infinite}
    h1{font-size:clamp(40px,7.5vw,84px);line-height:1.04;letter-spacing:-.035em;margin:26px 0 18px;font-weight:800}
    h1 .grad{background:linear-gradient(100deg,#8f83ff 0%,#d94bd0 45%,#7ce7f5 100%);
      -webkit-background-clip:text;background-clip:text;color:transparent;
      background-size:200% 100%;animation:grad-slide 6s ease-in-out infinite}
    .sub{max-width:640px;margin:0 auto;color:#9aa3c7;font-size:clamp(15px,2vw,19px)}
    .ctas{display:flex;gap:14px;justify-content:center;margin-top:38px;flex-wrap:wrap}
    .btn{position:relative;display:inline-flex;align-items:center;gap:10px;padding:15px 30px;border-radius:14px;
      font-weight:700;font-size:15px;cursor:pointer;border:1px solid var(--border);color:#e7e9f4;
      background:rgba(20,26,51,.55);backdrop-filter:blur(8px);transition:transform .2s,box-shadow .2s;overflow:hidden}
    .btn:hover{transform:translateY(-3px)}
    .btn.primary{border-color:transparent;background:linear-gradient(120deg,#8f83ff,#7a3cf0 55%,#d94bd0)}
    .btn.primary::after{content:"";position:absolute;inset:0;background:linear-gradient(120deg,transparent 30%,rgba(255,255,255,.35) 50%,transparent 70%);
      transform:translateX(-120%);animation:sheen 3.6s ease-in-out infinite}
    .btn.primary:hover{box-shadow:0 12px 44px rgba(143,131,255,.45)}
    .btn.ghost:hover{border-color:#8f83ff;box-shadow:0 8px 30px rgba(143,131,255,.25)}
    .scroll-hint{position:absolute;bottom:24px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;
      align-items:center;gap:9px;color:#9aa3c7;font-size:10px;letter-spacing:.28em;text-transform:uppercase}
    .mouse{width:26px;height:42px;border:1.5px solid rgba(154,163,199,.65);border-radius:14px;position:relative;
      box-shadow:0 0 16px rgba(124,231,245,.18),inset 0 0 8px rgba(143,131,255,.12)}
    .mouse i{position:absolute;left:50%;top:7px;width:4px;height:9px;margin-left:-2px;border-radius:3px;
      background:linear-gradient(#7ce7f5,#8f83ff);animation:wheel 1.8s ease-in-out infinite}
    @keyframes wheel{0%{transform:translateY(0);opacity:1}70%{transform:translateY(15px);opacity:0}100%{transform:translateY(0);opacity:0}}
    /* story sections */
    .story{padding:18vh 0}
    .kicker{font:600 11px/1 ui-monospace,monospace;letter-spacing:.22em;text-transform:uppercase;color:#7ce7f5;margin-bottom:14px}
    h2{font-size:clamp(28px,4.6vw,52px);letter-spacing:-.03em;line-height:1.1;font-weight:800;max-width:760px}
    .lead{color:#9aa3c7;max-width:620px;margin-top:16px;font-size:17px}
    .cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:18px;margin-top:52px;perspective:1200px}
    .card{position:relative;border:1px solid var(--border);border-radius:20px;padding:28px;
      background:linear-gradient(150deg,rgba(20,26,51,.75),rgba(8,10,22,.85));backdrop-filter:blur(10px);
      transform-style:preserve-3d;transition:transform .35s cubic-bezier(.16,1,.3,1),box-shadow .35s;will-change:transform}
    .card:hover{box-shadow:0 24px 70px rgba(122,60,240,.28)}
    .card .ico{font-size:34px}
    .card h3{margin:14px 0 8px;font-size:19px;letter-spacing:-.01em}
    .card p{color:#9aa3c7;font-size:14px}
    .card .glowline{position:absolute;left:28px;right:28px;top:0;height:1px;
      background:linear-gradient(90deg,transparent,var(--brand),transparent);opacity:.6}
    /* parallax statements */
    .statement{min-height:52vh;display:flex;align-items:center}
    .statement .big{font-size:clamp(30px,5.4vw,64px);font-weight:800;letter-spacing:-.03em;line-height:1.08;max-width:820px}
    .statement .big em{font-style:normal;background:linear-gradient(100deg,#d94bd0,#7ce7f5);-webkit-background-clip:text;background-clip:text;color:transparent}
    /* founder */
    .founder{padding:16vh 0}
    .founder-card{display:flex;gap:38px;align-items:center;flex-wrap:wrap;border:1px solid var(--border);border-radius:26px;
      padding:40px;background:linear-gradient(140deg,rgba(122,60,240,.14),rgba(8,10,22,.9) 60%);backdrop-filter:blur(12px)}
    .founder-photo{position:relative;flex:0 0 auto}
    .founder-photo img{width:190px;height:190px;object-fit:cover;border-radius:50%;display:block;
      border:2px solid rgba(143,131,255,.5)}
    .founder-photo::before{content:"";position:absolute;inset:-14px;border-radius:50%;
      background:conic-gradient(from 0deg,#8f83ff,#d94bd0,#7ce7f5,#8f83ff);filter:blur(18px);opacity:.5;z-index:-1;
      animation:spin 9s linear infinite}
    .founder h3{font-size:24px;letter-spacing:-.02em}
    .founder .role{color:#7ce7f5;font:600 11px/1 ui-monospace,monospace;letter-spacing:.2em;text-transform:uppercase;margin:6px 0 14px}
    .founder blockquote{color:#b9c0dd;font-size:16px;line-height:1.7;max-width:560px}
    /* final cta */
    .finale{padding:18vh 0 22vh;text-align:center}
    footer{position:relative;z-index:2;padding:0 0 30px;color:#9aa3c7;font-size:13.5px}
    footer::before{content:"";display:block;height:1px;margin-bottom:38px;
      background:linear-gradient(90deg,transparent,rgba(143,131,255,.55),rgba(124,231,245,.45),transparent)}
    .foot-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:34px;align-items:start}
    .foot-grid .logo{font-weight:800;font-size:16px;color:#e7e9f4}
    .foot-grid p{margin-top:10px;max-width:320px;line-height:1.65}
    .foot-col b{display:block;color:#e7e9f4;font-size:12px;letter-spacing:.14em;text-transform:uppercase;margin-bottom:12px}
    .foot-col a{display:block;color:#9aa3c7;padding:4px 0;transition:.15s}
    .foot-col a:hover{color:#7ce7f5}
    .fine{margin-top:34px;padding-top:18px;border-top:1px solid var(--border);display:flex;gap:12px;flex-wrap:wrap;
      justify-content:space-between;color:#6f77a0;font-size:12.5px}
    @media (max-width:720px){.foot-grid{grid-template-columns:1fr;gap:24px}}
    /* reveal animation */
    .reveal{opacity:0;transform:translateY(46px);transition:opacity .9s cubic-bezier(.16,1,.3,1),transform .9s cubic-bezier(.16,1,.3,1)}
    .reveal.in{opacity:1;transform:none}
    .reveal[data-delay="1"]{transition-delay:.12s}.reveal[data-delay="2"]{transition-delay:.24s}.reveal[data-delay="3"]{transition-delay:.36s}
    /* toast */
    #toast{position:fixed;bottom:30px;left:50%;transform:translate(-50%,20px);z-index:50;opacity:0;pointer-events:none;
      background:#141a33;border:1px solid var(--border);border-radius:12px;padding:12px 22px;font-size:14px;
      transition:opacity .3s,transform .3s;box-shadow:0 16px 50px rgba(0,0,0,.5)}
    #toast.show{opacity:1;transform:translate(-50%,0)}
    @keyframes grad-slide{0%,100%{background-position:0% 0}50%{background-position:100% 0}}
    @keyframes sheen{0%,55%{transform:translateX(-120%)}85%,100%{transform:translateX(120%)}}
    @keyframes bob{0%,100%{transform:translate(-50%,0)}50%{transform:translate(-50%,10px)}}
    @keyframes pulse-glow{0%,100%{box-shadow:0 0 0 0 rgba(124,231,245,.25)}50%{box-shadow:0 0 24px 2px rgba(124,231,245,.25)}}
    @keyframes spin{to{transform:rotate(360deg)}}
    @media (prefers-reduced-motion: reduce){
      .reveal{opacity:1;transform:none;transition:none}
      h1 .grad,.btn.primary::after,.mouse i,.founder-photo::before,.eyebrow,nav{animation:none}
    }
    /* mobile: the capsule nav compacts and wraps instead of overflowing */
    @media (max-width:640px){
      nav{gap:8px;padding:8px 10px 8px 16px}
      nav .logo{font-size:14px}
      nav .links a{font-size:11.5px;padding:5px 8px}
      .wrap{padding:0 18px}
      .ctas .btn{padding:13px 22px;font-size:14px}
      .founder-card{padding:26px}
    }
  </style>
</head>
<body>
  <canvas id="sky"></canvas>
  <div class="veil"></div>

  <nav>
    <a class="logo" href={`${base}/`}>🌳 Claude Galaxy</a>
    <div class="links">
      <a href={`${base}/toolkit`}>Toolkit</a>
      <a href={`${base}/changelog`}>Changelog</a>
      <a href={`${base}/download`}>Download</a>
      <a href={`${base}/dashboard/`}>Web demo ↗</a>
      <a href="https://github.com/Dontag/claude-toolkit">GitHub ↗</a>
    </div>
  </nav>

  <section class="hero">
    <div class="hero-inner wrap" data-parallax="0.18">
      <span class="eyebrow reveal in">A living universe for Claude Code</span>
      <h1>Your Claude setup,<br /><span class="grad">alive in a galaxy.</span></h1>
      <p class="sub">
        Skills, agents, hooks and commands grow as fruit on a 3D tree that watches your
        <code>.claude</code> folder in real time. Share your best work to a shared galaxy —
        one solar system per creator, orbiting a black hole.
      </p>
      <div class="ctas">
        <a class="btn primary" href={`${base}/app/`}>🌌 Explore online <span style="opacity:.7;font-weight:500;font-size:12px">limited</span></a>
        <button class="btn ghost" id="downloadBtn">⬇ Download the desktop app</button>
      </div>
    </div>
    <div class="scroll-hint"><span class="mouse"><i></i></span><span>scroll</span></div>
  </section>

  <section class="story">
    <div class="wrap">
      <div class="kicker reveal">Why this exists</div>
      <h2 class="reveal">Claude setups are invisible.<br />Yours should be a place.</h2>
      <p class="lead reveal" data-delay="1">
        Your skills and agents are just markdown files in a hidden folder. You forget what you have,
        you can't see it grow, and sharing means pasting files in chat. Claude Galaxy turns that
        folder into a world you can see, tend, and share.
      </p>
      <div class="cards">
        <div class="card reveal tilt" data-delay="1">
          <span class="glowline"></span>
          <div class="ico">🌱</div>
          <h3>A tree that grows with you</h3>
          <p>Every skill, agent, command and hook is a glowing fruit. Add a file — a fruit grows in.
             Delete one — it falls with physics. Over 10 in a category? A new branch grows automatically.</p>
        </div>
        <div class="card reveal tilt" data-delay="2">
          <span class="glowline"></span>
          <div class="ico">🌌</div>
          <h3>A galaxy of creators</h3>
          <p>Share any item with one toggle. Every user is a solar system — planets grouped in orbital
             lanes by kind, dust swirling around each one, comets streaking when the community works.</p>
        </div>
        <div class="card reveal tilt" data-delay="3">
          <span class="glowline"></span>
          <div class="ico">🔐</div>
          <h3>Editing with guardrails</h3>
          <p>Others request changes; you grant an exclusive 30-minute window. Their edit arrives as a
             proposal you approve or reject — nothing replaces your work without your yes.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="statement">
    <div class="wrap"><p class="big reveal" data-parallax="0.1">Watch your toolkit <em>grow like a garden</em> — live, as you and Claude work.</p></div>
  </section>
  <section class="statement">
    <div class="wrap"><p class="big reveal" data-parallax="0.14">Graft the best skills of other builders <em>straight onto your tree.</em></p></div>
  </section>
  <section class="statement">
    <div class="wrap"><p class="big reveal" data-parallax="0.18">Your work stays yours — <em>every change needs your approval.</em></p></div>
  </section>

  <section class="founder">
    <div class="wrap">
      <div class="founder-card reveal">
        <div class="founder-photo"><img src={`${base}/img/founder.jpeg`} alt="Founder" /></div>
        <div>
          <h3>Nishad Patil</h3>
          <div class="role">Founder & Builder</div>
          <blockquote>
            “I built this because my <code>.claude</code> folder became the most valuable directory on my
            machine — and I had no way to see it, grow it, or share it. Now it's a tree in a galaxy,
            and everyone's best work can orbit together. This is how sharing AI tooling should feel.”
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <section class="finale">
    <div class="wrap">
      <div class="kicker reveal">Ready?</div>
      <h2 class="reveal" style="max-width:none">Plant your tree. Join the galaxy.</h2>
      <div class="ctas reveal" data-delay="1">
        <a class="btn primary" href={`${base}/app/`}>🌌 Explore online</a>
        <button class="btn ghost" id="downloadBtn2">⬇ Download the desktop app</button>
      </div>
    </div>
  </section>

  <footer>
    <div class="wrap foot-grid">
      <div>
        <div class="logo">🌌 Claude Galaxy</div>
        <p>Your Claude setup as a living tree — and a shared galaxy where every creator is a solar
           system orbiting the same black hole.</p>
      </div>
      <div class="foot-col">
        <b>Product</b>
        <a href={`${base}/toolkit`}>Toolkit</a>
        <a href={`${base}/changelog`}>Changelog</a>
        <a href={`${base}/download`}>Download</a>
        <a href={`${base}/app/`}>Explore online</a>
      </div>
      <div class="foot-col">
        <b>Project</b>
        <a href="https://github.com/Dontag/claude-toolkit">GitHub</a>
        <a href="https://github.com/Dontag/claude-toolkit/issues/new">Report an issue</a>
        <a href={`${base}/dashboard/`}>Web demo</a>
      </div>
    </div>
    <div class="wrap fine">
      <span>© 2026 Claude Galaxy · Crafted by Nishad Patil</span>
      <span>Open source · Built with Claude Code</span>
    </div>
  </footer>

  <div id="toast"></div>
  <script id="dl-data" type="application/json" set:html={JSON.stringify(downloads)}></script>

  <script>
    import * as THREE from "three";

    /* ── toast ── */
    const toastEl = document.getElementById("toast")!;
    let toastT: ReturnType<typeof setTimeout>;
    function toast(msg: string) {
      toastEl.textContent = msg;
      toastEl.classList.add("show");
      clearTimeout(toastT);
      toastT = setTimeout(() => toastEl.classList.remove("show"), 2800);
    }
    /* ── platform-aware desktop download ──
       detect the visitor's OS, relabel the buttons, and serve the matching
       installer from the latest GitHub release; fall back to the /download
       page (all platforms + coming-soon state) when no asset is available. */
    interface Downloads { version: string | null; windows: string | null; mac: string | null; linux: string | null; page: string }
    const dl = JSON.parse(document.getElementById("dl-data")!.textContent!) as Downloads;

    function detectOS(): "windows" | "mac" | "linux" | null {
      const nav = navigator as Navigator & { userAgentData?: { platform?: string } };
      const s = (nav.userAgentData?.platform || navigator.platform || navigator.userAgent).toLowerCase();
      // phones/tablets have no desktop build → route them to the download page
      if (/android|iphone|ipad|ipod/.test(navigator.userAgent.toLowerCase())) return null;
      if (s.includes("win")) return "windows";
      if (s.includes("mac")) return "mac";
      if (s.includes("linux")) return "linux";
      return null;
    }
    const OS_LABEL = { windows: "Windows", mac: "macOS", linux: "Linux" } as const;
    const os = detectOS();
    const assetUrl = os ? dl[os] : null;

    for (const id of ["downloadBtn", "downloadBtn2"]) {
      const btn = document.getElementById(id);
      if (!btn) continue;
      if (os) btn.textContent = `⬇ Download for ${OS_LABEL[os]}`;
      btn.addEventListener("click", () => {
        if (assetUrl) {
          toast(`⬇ Downloading Claude Galaxy${dl.version ? " v" + dl.version : ""} for ${OS_LABEL[os!]}…`);
          location.href = assetUrl;
        } else {
          // no build for this OS yet (or unknown OS) → the full download page
          location.href = dl.page;
        }
      });
    }

    /* ── scroll reveals ── */
    const io = new IntersectionObserver(
      (entries) => entries.forEach((e) => e.isIntersecting && e.target.classList.add("in")),
      { threshold: 0.18 },
    );
    document.querySelectorAll(".reveal").forEach((el) => io.observe(el));

    /* ── card tilt ── */
    document.querySelectorAll<HTMLElement>(".tilt").forEach((card) => {
      card.addEventListener("mousemove", (e) => {
        const r = card.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top) / r.height - 0.5;
        card.style.transform = `rotateY(${x * 10}deg) rotateX(${-y * 10}deg) translateZ(8px)`;
      });
      card.addEventListener("mouseleave", () => (card.style.transform = ""));
    });

    /* ── parallax layers ── */
    const parallaxEls = [...document.querySelectorAll<HTMLElement>("[data-parallax]")];
    addEventListener("scroll", () => {
      const y = scrollY;
      for (const el of parallaxEls) {
        el.style.transform = `translateY(${y * -parseFloat(el.dataset.parallax!)}px)`;
      }
    }, { passive: true });

    /* ── 3D nebula sky ── */
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const canvas = document.getElementById("sky") as HTMLCanvasElement;
    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
    renderer.setSize(innerWidth, innerHeight);
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(55, innerWidth / innerHeight, 0.1, 400);
    camera.position.z = 60;

    function softTex(): THREE.CanvasTexture {
      const c = document.createElement("canvas");
      c.width = c.height = 64;
      const x = c.getContext("2d")!;
      const g = x.createRadialGradient(32, 32, 0, 32, 32, 32);
      g.addColorStop(0, "rgba(255,255,255,.9)");
      g.addColorStop(0.35, "rgba(255,255,255,.32)");
      g.addColorStop(1, "rgba(255,255,255,0)");
      x.fillStyle = g;
      x.fillRect(0, 0, 64, 64);
      return new THREE.CanvasTexture(c);
    }
    function nebulaTex(seed: number): THREE.CanvasTexture {
      const S = 256, c = document.createElement("canvas");
      c.width = c.height = S;
      const x = c.getContext("2d")!;
      let s = seed;
      const rnd = () => ((s = (s * 16807) % 2147483647) - 1) / 2147483646;
      x.globalCompositeOperation = "lighter";
      const tints = [[150,40,200],[200,50,170],[110,40,210],[210,90,230]];
      for (let i = 0; i < 55; i++) {
        const cx = rnd()*S, cy = rnd()*S, r = 22 + rnd()*85;
        const [rr,gg,bb] = tints[(rnd()*tints.length)|0];
        const g = x.createRadialGradient(cx,cy,0,cx,cy,r);
        g.addColorStop(0, `rgba(${rr},${gg},${bb},${0.05+rnd()*0.11})`);
        g.addColorStop(1, "rgba(0,0,0,0)");
        x.fillStyle = g; x.beginPath(); x.arc(cx,cy,r,0,7); x.fill();
      }
      return new THREE.CanvasTexture(c);
    }

    const glow = softTex();
    // star layers (parallax depths)
    const starLayers: THREE.Points[] = [];
    for (const [count, spread, size, op] of [[900, 160, 1.1, .9],[600, 110, .8, .6],[350, 80, .6, .4]] as const) {
      const pos = new Float32Array(count * 3);
      const col = new Float32Array(count * 3);
      const palette = [0xffffff, 0x8f83ff, 0x7ce7f5, 0xd94bd0, 0xffb057];
      for (let i = 0; i < count; i++) {
        pos[i*3] = (Math.random()-0.5)*spread*2;
        pos[i*3+1] = (Math.random()-0.5)*spread*1.2;
        pos[i*3+2] = (Math.random()-0.5)*spread - 20;
        const c = new THREE.Color(palette[Math.random() < .7 ? 0 : 1 + ((Math.random()*4)|0)]);
        col[i*3]=c.r; col[i*3+1]=c.g; col[i*3+2]=c.b;
      }
      const g = new THREE.BufferGeometry();
      g.setAttribute("position", new THREE.BufferAttribute(pos, 3));
      g.setAttribute("color", new THREE.BufferAttribute(col, 3));
      const p = new THREE.Points(g, new THREE.PointsMaterial({ size, map: glow, vertexColors: true, transparent: true, opacity: op, depthWrite: false, blending: THREE.AdditiveBlending }));
      scene.add(p);
      starLayers.push(p);
    }
    // nebula billboards
    const nebulae: THREE.Sprite[] = [];
    const nTex = [nebulaTex(11), nebulaTex(22), nebulaTex(33)];
    const nCol = [0xa64bff, 0xd94bd0, 0x7a3cf0, 0xff5ad0];
    for (let i = 0; i < 9; i++) {
      const sp = new THREE.Sprite(new THREE.SpriteMaterial({ map: nTex[i % 3], color: nCol[i % 4], transparent: true, opacity: .34, blending: THREE.AdditiveBlending, depthWrite: false, rotation: Math.random()*7 }));
      sp.position.set((Math.random()-.5)*220, (Math.random()-.5)*130, -40 - Math.random()*60);
      const s = 120 + Math.random()*120;
      sp.scale.set(s, s*.72, 1);
      scene.add(sp);
      nebulae.push(sp);
    }
    /* planets — shaded sprite globes (one ringed) drifting at statement
       depths, so the tall scroll sections aren't empty space */
    function planetTex(tint: [number, number, number], ring: boolean, seed: number): THREE.CanvasTexture {
      const S = 256, c = document.createElement("canvas");
      c.width = c.height = S;
      const x = c.getContext("2d")!;
      let s = seed;
      const rnd = () => ((s = (s * 16807) % 2147483647) - 1) / 2147483646;
      const [r, g, b] = tint;
      const cx = S / 2, cy = S / 2, R = S * 0.34;
      // sphere shading: lit upper-left → deep shadow lower-right
      const grad = x.createRadialGradient(cx - R * 0.45, cy - R * 0.5, R * 0.1, cx, cy, R);
      grad.addColorStop(0, `rgba(${Math.min(255, r + 90)},${Math.min(255, g + 90)},${Math.min(255, b + 90)},1)`);
      grad.addColorStop(0.55, `rgba(${r},${g},${b},1)`);
      grad.addColorStop(1, `rgba(${(r * 0.25) | 0},${(g * 0.25) | 0},${(b * 0.25) | 0},1)`);
      x.fillStyle = grad;
      x.beginPath(); x.arc(cx, cy, R, 0, 7); x.fill();
      // faint latitude bands
      x.save();
      x.beginPath(); x.arc(cx, cy, R, 0, 7); x.clip();
      for (let i = 0; i < 5; i++) {
        x.fillStyle = `rgba(255,255,255,${0.04 + rnd() * 0.05})`;
        x.fillRect(cx - R, cy - R + rnd() * R * 2, R * 2, 2 + rnd() * 7);
      }
      x.restore();
      // atmosphere rim
      x.strokeStyle = `rgba(${Math.min(255, r + 70)},${Math.min(255, g + 70)},${Math.min(255, b + 70)},.5)`;
      x.lineWidth = 2.5;
      x.beginPath(); x.arc(cx, cy, R + 1.5, 0, 7); x.stroke();
      if (ring) {
        x.strokeStyle = `rgba(${Math.min(255, r + 60)},${Math.min(255, g + 60)},${Math.min(255, b + 60)},.55)`;
        x.lineWidth = 5;
        x.beginPath(); x.ellipse(cx, cy, R * 1.7, R * 0.5, -0.42, 0, 7); x.stroke();
        x.strokeStyle = `rgba(255,255,255,.22)`;
        x.lineWidth = 2;
        x.beginPath(); x.ellipse(cx, cy, R * 1.95, R * 0.58, -0.42, 0, 7); x.stroke();
      }
      return new THREE.CanvasTexture(c);
    }
    const planets: Array<{ m: THREE.Sprite; depth: number; bob: number }> = [];
    const planetDefs: Array<[[number, number, number], boolean, number, [number, number, number], number]> = [
      // [tint, ringed, size, position, seed]
      [[122, 60, 240], false, 30, [-78, 14, -55], 5],
      [[46, 197, 255], true, 46, [72, -46, -80], 9],
      [[217, 75, 160], false, 20, [38, 64, -95], 13],
    ];
    for (const [tint, ring, size, [px, py, pz], seed] of planetDefs) {
      const m = new THREE.Sprite(new THREE.SpriteMaterial({ map: planetTex(tint, ring, seed), transparent: true, depthWrite: false }));
      m.position.set(px, py, pz);
      m.scale.set(size, size, 1);
      scene.add(m);
      planets.push({ m, depth: 0.4 + Math.random() * 0.5, bob: Math.random() * 7 });
    }
    /* asteroid stream — small tumbling rocks drifting across the deep field */
    function rockTex(seed: number): THREE.CanvasTexture {
      const S = 64, c = document.createElement("canvas");
      c.width = c.height = S;
      const x = c.getContext("2d")!;
      let s = seed;
      const rnd = () => ((s = (s * 16807) % 2147483647) - 1) / 2147483646;
      x.fillStyle = "rgba(140,132,120,1)";
      x.beginPath();
      for (let i = 0; i <= 9; i++) {
        const a = (i / 9) * Math.PI * 2;
        const r = S * (0.24 + rnd() * 0.14);
        const px = S / 2 + Math.cos(a) * r, py = S / 2 + Math.sin(a) * r;
        i ? x.lineTo(px, py) : x.moveTo(px, py);
      }
      x.closePath(); x.fill();
      x.fillStyle = "rgba(0,0,0,.35)";
      for (let i = 0; i < 5; i++) {
        x.beginPath(); x.arc(S * (0.3 + rnd() * 0.4), S * (0.3 + rnd() * 0.4), 2 + rnd() * 4, 0, 7); x.fill();
      }
      return new THREE.CanvasTexture(c);
    }
    const rocks: Array<{ m: THREE.Sprite; v: number; rs: number }> = [];
    for (let i = 0; i < 9; i++) {
      const m = new THREE.Sprite(new THREE.SpriteMaterial({ map: rockTex(31 + i * 7), transparent: true, opacity: 0.85, depthWrite: false, rotation: Math.random() * 7 }));
      m.position.set((Math.random() - 0.5) * 300, (Math.random() - 0.5) * 120, -30 - Math.random() * 70);
      const s = 1.2 + Math.random() * 2.4;
      m.scale.set(s, s, 1);
      scene.add(m);
      rocks.push({ m, v: 2 + Math.random() * 4, rs: (Math.random() - 0.5) * 0.6 });
    }

    // occasional comet
    interface Comet { m: THREE.Sprite; v: THREE.Vector3; life: number }
    let comet: Comet | null = null;
    let nextComet = performance.now() + 4000;
    function spawnComet(): Comet {
      const m = new THREE.Sprite(new THREE.SpriteMaterial({ map: glow, color: nCol[(Math.random()*4)|0], transparent: true, blending: THREE.AdditiveBlending, depthWrite: false }));
      m.scale.set(4, 4, 1);
      const side = Math.random() < .5 ? -1 : 1;
      m.position.set(side * 140, 30 + Math.random()*50, -30);
      scene.add(m);
      return { m, v: new THREE.Vector3(-side * (40 + Math.random()*25), -(12 + Math.random()*10), 0), life: 0 };
    }

    const mouse = { x: 0, y: 0 };
    addEventListener("pointermove", (e) => {
      mouse.x = (e.clientX / innerWidth) * 2 - 1;
      mouse.y = (e.clientY / innerHeight) * 2 - 1;
    });
    addEventListener("resize", () => {
      camera.aspect = innerWidth / innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(innerWidth, innerHeight);
    });

    const clock = new THREE.Clock();
    (function animate() {
      requestAnimationFrame(animate);
      const dt = Math.min(clock.getDelta(), .05);
      const t = clock.elapsedTime;
      const sy = scrollY * 0.02;
      // mouse + scroll parallax at different depths
      starLayers.forEach((p, i) => {
        const depth = (i + 1) / starLayers.length;
        p.position.x += ((-mouse.x * 8 * depth) - p.position.x) * .04;
        p.position.y += ((mouse.y * 5 * depth + sy * depth * 2) - p.position.y) * .04;
        p.rotation.z += dt * .004 * (i % 2 ? 1 : -1);
        (p.material as THREE.PointsMaterial).opacity = [.9,.6,.4][i] + Math.sin(t * (.5 + i*.2)) * .08;
      });
      nebulae.forEach((n, i) => {
        n.material.rotation += dt * .012 * (i % 2 ? 1 : -1);
        n.material.opacity = .3 + Math.sin(t * .2 + i) * .09;
        n.position.y += Math.sin(t * .1 + i * 2) * .01;
      });
      // planets bob gently and ride the scroll at their own depths
      planets.forEach((p, i) => {
        p.m.position.y += (Math.sin(t * 0.14 + p.bob) * 0.012);
        p.m.position.x += ((-mouse.x * 4 * p.depth) - (p.m.position.x - planetDefs[i]![3][0])) * 0.02;
      });
      // asteroids tumble slowly across the field, wrapping at the edges
      for (const r of rocks) {
        r.m.position.x += r.v * dt;
        r.m.material.rotation += r.rs * dt;
        if (r.m.position.x > 165) r.m.position.x = -165;
      }
      if (!reduced && performance.now() > nextComet && !comet) comet = spawnComet();
      if (comet) {
        comet.life += dt;
        comet.m.position.addScaledVector(comet.v, dt);
        comet.m.material.opacity = Math.max(0, 1 - comet.life / 4);
        if (comet.life > 4) {
          scene.remove(comet.m);
          comet = null;
          nextComet = performance.now() + 6000 + Math.random() * 14000;
        }
      }
      renderer.render(scene, camera);
    })();
  </script>
</body>
</html>
