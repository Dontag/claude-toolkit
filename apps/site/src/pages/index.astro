---
// Cinematic parallax landing — 3D nebula hero, story scroll, founder, CTAs.
import { resolveDownloads } from "../lib/downloads";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Per-OS installer (GitHub release asset, else a manual/OneDrive link) so the
// hero "Download" button can serve the visitor's platform directly; when none
// is set the client routes to the /download page.
const r = resolveDownloads();
const downloads = { version: r.version, windows: r.windows, mac: r.mac, linux: r.linux, page: `${base}/download` };
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#05030f" />
  <meta name="description" content="Claude Galaxy — your Claude setup as a living 3D tree, and a shared galaxy of skills." />
  <link rel="icon" type="image/svg+xml" href={`${base}/logo.svg`} />
  <title>Claude Galaxy — a living galaxy for your Claude setup</title>
  <style>
    :root{
      --bg:#05030f; --text:#e7e9f4; --muted:#9aa3c7; --border:rgba(151,161,204,.16);
      --brand:#8f83ff; --brand2:#7ce7f5; --magenta:#d94bd0; --violet:#7a3cf0;
    }
    *{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth;background:var(--bg)}
    body{background:var(--bg);color:#e7e9f4;font:16px/1.6 Inter,system-ui,-apple-system,"Segoe UI",sans-serif;overflow-x:hidden}
    a{color:#7ce7f5;text-decoration:none}
    /* fixed 3D sky behind everything */
    #sky{position:fixed;inset:0;z-index:0}
    .veil{position:fixed;inset:0;z-index:1;pointer-events:none;
      background:radial-gradient(115% 78% at 50% 12%,transparent 20%,rgba(5,3,15,.5) 62%,rgba(5,3,15,.95) 100%)}
    /* nav — floating glowing capsule with an animated conic aura ring */
    nav{position:fixed;top:16px;left:50%;transform:translateX(-50%);z-index:20;display:flex;align-items:center;gap:10px;
      width:max-content;max-width:calc(100vw - 20px);padding:8px 10px 8px 16px;border-radius:999px;
      border:1px solid rgba(143,131,255,.35);background:rgba(8,10,25,.6);backdrop-filter:blur(16px) saturate(1.2);
      box-shadow:0 8px 40px rgba(5,3,15,.6),0 0 26px rgba(143,131,255,.18),inset 0 1px 0 rgba(255,255,255,.06)}
    /* soft static aura behind the capsule (no rotation) */
    nav::before{content:"";position:absolute;inset:-2px;border-radius:999px;pointer-events:none;z-index:-1;
      background:linear-gradient(100deg,rgba(143,131,255,.4),rgba(217,75,208,.28),rgba(124,231,245,.4));
      filter:blur(10px);opacity:.4}
    /* crisp gradient border on top */
    nav::after{content:"";position:absolute;inset:0;border-radius:999px;pointer-events:none;padding:1px;
      background:linear-gradient(100deg,rgba(143,131,255,.7),rgba(217,75,208,.5),rgba(124,231,245,.7));
      -webkit-mask:linear-gradient(#fff 0 0) padding-box,linear-gradient(#fff 0 0);
      -webkit-mask-composite:xor;mask-composite:exclude}
    nav .logo{display:flex;align-items:center;gap:8px;font-weight:800;letter-spacing:-.02em;color:#e7e9f4;white-space:nowrap;padding-right:4px}
    nav .logo img{width:26px;height:26px;filter:drop-shadow(0 0 8px rgba(143,131,255,.6))}
    nav .links{display:flex;gap:2px;align-items:center}
    nav .links a{position:relative;color:#aab2d4;font-size:13px;font-weight:500;padding:7px 13px;border-radius:99px;transition:.18s;white-space:nowrap}
    nav .links a::after{content:"";position:absolute;left:13px;right:13px;bottom:4px;height:1.5px;border-radius:2px;
      background:linear-gradient(90deg,#8f83ff,#7ce7f5);transform:scaleX(0);transform-origin:left;transition:transform .22s}
    nav .links a:hover{color:#fff}
    nav .links a:hover::after{transform:scaleX(1)}
    nav .links a.cta{color:#fff;background:linear-gradient(120deg,#8f83ff,#7a3cf0 60%,#d94bd0);font-weight:700;
      box-shadow:0 4px 18px rgba(122,60,240,.4)}
    nav .links a.cta::after{display:none}
    nav .links a.cta:hover{filter:brightness(1.1);transform:translateY(-1px)}
    @keyframes halo-spin{to{transform:rotate(360deg)}}
    section{position:relative;z-index:2}
    .wrap{max-width:1080px;margin:0 auto;padding:0 28px}
    /* hero */
    .hero{min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center}
    .hero-inner{transform:translateZ(0)}
    .hero-mark{width:88px;height:88px;margin:0 auto 6px;display:block;
      filter:drop-shadow(0 0 26px rgba(143,131,255,.55));animation:float-mark 5s ease-in-out infinite}
    @keyframes float-mark{0%,100%{transform:translateY(0) rotate(-2deg)}50%{transform:translateY(-12px) rotate(2deg)}}
    .eyebrow{display:inline-block;font:600 11px/1 ui-monospace,monospace;letter-spacing:.22em;text-transform:uppercase;
      color:#7ce7f5;border:1px solid rgba(124,231,245,.35);padding:8px 14px;border-radius:99px;
      background:rgba(124,231,245,.06);animation:pulse-glow 3s ease-in-out infinite}
    h1{font-size:clamp(40px,7.5vw,84px);line-height:1.04;letter-spacing:-.035em;margin:26px 0 18px;font-weight:800}
    h1 .grad{background:linear-gradient(100deg,#8f83ff 0%,#d94bd0 45%,#7ce7f5 100%);
      -webkit-background-clip:text;background-clip:text;color:transparent;
      background-size:200% 100%;animation:grad-slide 6s ease-in-out infinite}
    .sub{max-width:640px;margin:0 auto;color:#9aa3c7;font-size:clamp(15px,2vw,19px)}
    .ctas{display:flex;gap:14px;justify-content:center;margin-top:38px;flex-wrap:wrap}
    .btn{position:relative;display:inline-flex;align-items:center;gap:10px;padding:15px 30px;border-radius:14px;
      font-weight:700;font-size:15px;cursor:pointer;border:1px solid var(--border);color:#e7e9f4;
      background:rgba(20,26,51,.55);backdrop-filter:blur(8px);transition:transform .2s,box-shadow .2s;overflow:hidden}
    .btn:hover{transform:translateY(-3px)}
    .btn.primary{border-color:transparent;background:linear-gradient(120deg,#8f83ff,#7a3cf0 55%,#d94bd0)}
    .btn.primary::after{content:"";position:absolute;inset:0;background:linear-gradient(120deg,transparent 30%,rgba(255,255,255,.35) 50%,transparent 70%);
      transform:translateX(-120%);animation:sheen 3.6s ease-in-out infinite}
    .btn.primary:hover{box-shadow:0 12px 44px rgba(143,131,255,.45)}
    .btn.ghost:hover{border-color:#8f83ff;box-shadow:0 8px 30px rgba(143,131,255,.25)}
    .scroll-hint{position:absolute;bottom:26px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;
      align-items:center;gap:8px;font-size:10px;letter-spacing:.3em;text-transform:uppercase}
    .mouse{width:28px;height:46px;border-radius:16px;position:relative;
      background:linear-gradient(rgba(143,131,255,.1),rgba(124,231,245,.05));
      box-shadow:0 0 24px rgba(124,231,245,.2),inset 0 0 10px rgba(143,131,255,.14)}
    .mouse::before{content:"";position:absolute;inset:0;border-radius:16px;padding:1.5px;pointer-events:none;
      background:linear-gradient(180deg,#8f83ff,#7ce7f5);
      -webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);-webkit-mask-composite:xor;mask-composite:exclude}
    .mouse i{position:absolute;left:50%;top:8px;width:5px;height:10px;margin-left:-2.5px;border-radius:4px;
      background:linear-gradient(#fff,#7ce7f5);box-shadow:0 0 10px #7ce7f5;animation:wheel 1.8s cubic-bezier(.5,0,.5,1) infinite}
    .scroll-hint .chev{width:9px;height:9px;border-right:2px solid rgba(124,231,245,.7);border-bottom:2px solid rgba(124,231,245,.7);
      transform:rotate(45deg);animation:chev-bob 1.8s ease-in-out infinite}
    .scroll-hint .txt{background:linear-gradient(90deg,#8f83ff,#7ce7f5);-webkit-background-clip:text;background-clip:text;color:transparent;font-weight:700}
    @keyframes wheel{0%{transform:translateY(0);opacity:1}70%{transform:translateY(16px);opacity:0}100%{transform:translateY(0);opacity:0}}
    @keyframes chev-bob{0%,100%{transform:rotate(45deg) translate(0,0);opacity:.5}50%{transform:rotate(45deg) translate(3px,3px);opacity:1}}
    /* custom planet cursor (fine-pointer devices only) */
    #cursor{position:fixed;top:0;left:0;z-index:9999;pointer-events:none;display:none}
    #cursor .planet{position:absolute;width:22px;height:22px;margin:-11px;border-radius:50%;
      background:radial-gradient(circle at 34% 30%,#fff,#8f83ff 46%,#5a2fd0 100%);box-shadow:0 0 16px rgba(143,131,255,.7);
      transition:transform .18s cubic-bezier(.16,1,.3,1)}
    #cursor .ring{position:absolute;width:40px;height:40px;margin:-20px;border-radius:50%;border:1.5px solid transparent;
      border-top-color:#7ce7f5;border-right-color:#d94bd0;animation:cur-spin 2.2s linear infinite;transition:transform .18s}
    #cursor.hover .planet{transform:scale(1.55)}
    #cursor.hover .ring{transform:scale(1.3)}
    #cursor.down .planet{animation:cur-pop .45s ease}
    @keyframes cur-spin{to{transform:rotate(360deg)}}
    @keyframes cur-pop{0%{transform:scale(1)}35%{transform:scale(.6)}70%{transform:scale(1.4)}100%{transform:scale(1)}}
    body.has-cursor,body.has-cursor a,body.has-cursor button,body.has-cursor input{cursor:none}
    body.has-cursor #cursor{display:block}
    /* story sections */
    .story{padding:18vh 0}
    .kicker{font:600 11px/1 ui-monospace,monospace;letter-spacing:.22em;text-transform:uppercase;color:#7ce7f5;margin-bottom:14px}
    h2{font-size:clamp(28px,4.6vw,52px);letter-spacing:-.03em;line-height:1.1;font-weight:800;max-width:760px}
    .lead{color:#9aa3c7;max-width:620px;margin-top:16px;font-size:17px}
    .cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:18px;margin-top:52px;perspective:1200px}
    .card{position:relative;border:1px solid var(--border);border-radius:20px;padding:28px;
      background:linear-gradient(150deg,rgba(20,26,51,.75),rgba(8,10,22,.85));backdrop-filter:blur(10px);
      transform-style:preserve-3d;transition:transform .35s cubic-bezier(.16,1,.3,1),box-shadow .35s;will-change:transform}
    .card:hover{box-shadow:0 24px 70px rgba(122,60,240,.28)}
    .card .ico{font-size:34px}
    .card h3{margin:14px 0 8px;font-size:19px;letter-spacing:-.01em}
    .card p{color:#9aa3c7;font-size:14px}
    .card .glowline{position:absolute;left:28px;right:28px;top:0;height:1px;
      background:linear-gradient(90deg,transparent,var(--brand),transparent);opacity:.6}
    /* stats band */
    .stats{padding:9vh 0}
    .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
    .stat{text-align:center;border:1px solid var(--border);border-radius:18px;padding:26px 14px;
      background:linear-gradient(160deg,rgba(20,26,51,.55),rgba(8,10,22,.6));backdrop-filter:blur(8px);
      transition:transform .3s,box-shadow .3s}
    .stat:hover{transform:translateY(-4px);box-shadow:0 18px 50px rgba(122,60,240,.25)}
    .stat b{display:block;font-size:clamp(30px,4vw,46px);font-weight:800;letter-spacing:-.03em;line-height:1;
      background:linear-gradient(120deg,#8f83ff,#7ce7f5);-webkit-background-clip:text;background-clip:text;color:transparent}
    .stat span{display:block;margin-top:8px;font-size:12.5px;color:#9aa3c7;letter-spacing:.02em}
    @media (max-width:640px){.stats-grid{grid-template-columns:repeat(2,1fr)}}
    /* parallax statements — text on the left, a glowing planet card on the right */
    .statement{min-height:56vh;display:flex;align-items:center}
    .statement .row{display:grid;grid-template-columns:1.3fr .9fr;gap:40px;align-items:center;width:100%}
    .statement .big{font-size:clamp(30px,5vw,58px);font-weight:800;letter-spacing:-.03em;line-height:1.08}
    .statement .big em{font-style:normal;background:linear-gradient(100deg,#d94bd0,#7ce7f5);-webkit-background-clip:text;background-clip:text;color:transparent}
    .statement .note{margin-top:16px;color:#9aa3c7;font-size:16px;max-width:460px;line-height:1.6}
    .statement.rev .row{grid-template-columns:.9fr 1.3fr}
    .statement.rev .txt{order:2}
    /* orbit visual accompanying each statement */
    .orbit{position:relative;aspect-ratio:1;max-width:300px;margin:0 auto;width:100%}
    .orbit .core{position:absolute;inset:38%;border-radius:50%;
      background:radial-gradient(circle at 40% 35%,#fff,#8f83ff 45%,#5a2fd0 100%);
      box-shadow:0 0 40px rgba(143,131,255,.6),0 0 90px rgba(122,60,240,.35)}
    .orbit .ring{position:absolute;inset:0;border:1px solid rgba(143,131,255,.22);border-radius:50%;animation:orbit-spin 14s linear infinite}
    .orbit .ring:nth-child(2){inset:14%;border-color:rgba(124,231,245,.22);animation-duration:9s;animation-direction:reverse}
    .orbit .ring:nth-child(3){inset:26%;border-color:rgba(217,75,208,.22);animation-duration:20s}
    .orbit .ring i{position:absolute;top:-4px;left:50%;width:9px;height:9px;margin-left:-4px;border-radius:50%;
      background:#7ce7f5;box-shadow:0 0 12px #7ce7f5}
    .orbit .ring:nth-child(2) i{background:#d94bd0;box-shadow:0 0 12px #d94bd0}
    .orbit .ring:nth-child(3) i{background:#ffb057;box-shadow:0 0 12px #ffb057}
    @keyframes orbit-spin{to{transform:rotate(360deg)}}
    @media (max-width:760px){
      .statement .row,.statement.rev .row{grid-template-columns:1fr;gap:22px}
      .statement .txt,.statement.rev .txt{order:0}
      /* stagger the little systems L / R / L with varied size + tilt so they
         don't read as two identical circles stacked in a line */
      .statement .orbit{margin:0 auto 0 4%;max-width:190px;transform:rotate(-9deg)}
      .statement.rev .orbit{margin:0 4% 0 auto;max-width:240px;transform:rotate(11deg)}
      .statement:nth-of-type(2n) .orbit{max-width:210px}
    }
    /* founder */
    .founder{padding:16vh 0}
    .founder-card{display:flex;gap:38px;align-items:center;flex-wrap:wrap;border:1px solid var(--border);border-radius:26px;
      padding:40px;background:linear-gradient(140deg,rgba(122,60,240,.14),rgba(8,10,22,.9) 60%);backdrop-filter:blur(12px)}
    .founder-photo{position:relative;flex:0 0 auto}
    .founder-photo img{width:190px;height:190px;object-fit:cover;border-radius:50%;display:block;
      border:2px solid rgba(143,131,255,.5)}
    .founder-photo::before{content:"";position:absolute;inset:-14px;border-radius:50%;
      background:conic-gradient(from 0deg,#8f83ff,#d94bd0,#7ce7f5,#8f83ff);filter:blur(18px);opacity:.5;z-index:-1;
      animation:spin 9s linear infinite}
    .founder h3{font-size:24px;letter-spacing:-.02em}
    .founder .role{color:#7ce7f5;font:600 11px/1 ui-monospace,monospace;letter-spacing:.2em;text-transform:uppercase;margin:6px 0 14px}
    .founder blockquote{color:#b9c0dd;font-size:16px;line-height:1.7;max-width:560px}
    /* final cta */
    .finale{padding:18vh 0 22vh;text-align:center}
    footer{position:relative;z-index:2;padding:0 0 30px;color:#9aa3c7;font-size:13.5px}
    footer::before{content:"";display:block;height:1px;margin-bottom:38px;
      background:linear-gradient(90deg,transparent,rgba(143,131,255,.55),rgba(124,231,245,.45),transparent)}
    .foot-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:34px;align-items:start}
    .foot-grid .logo{font-weight:800;font-size:16px;color:#e7e9f4}
    .foot-grid p{margin-top:10px;max-width:320px;line-height:1.65}
    .foot-col b{display:block;color:#e7e9f4;font-size:12px;letter-spacing:.14em;text-transform:uppercase;margin-bottom:12px}
    .foot-col a{display:block;color:#9aa3c7;padding:4px 0;transition:.15s}
    .foot-col a:hover{color:#7ce7f5}
    .fine{margin-top:36px;padding-top:26px;border-top:1px solid var(--border);display:flex;gap:12px;flex-wrap:wrap;
      justify-content:space-between;color:#6f77a0;font-size:12.5px}
    @media (max-width:720px){.foot-grid{grid-template-columns:1fr;gap:24px}}
    @media (max-width:640px){.fine{flex-direction:column;gap:8px;padding-top:24px;margin-top:30px;text-align:center;justify-content:center}}
    /* reveal animation */
    .reveal{opacity:0;transform:translateY(46px);transition:opacity .9s cubic-bezier(.16,1,.3,1),transform .9s cubic-bezier(.16,1,.3,1)}
    .reveal.in{opacity:1;transform:none}
    .reveal[data-delay="1"]{transition-delay:.12s}.reveal[data-delay="2"]{transition-delay:.24s}.reveal[data-delay="3"]{transition-delay:.36s}
    /* toast */
    #toast{position:fixed;bottom:30px;left:50%;transform:translate(-50%,20px);z-index:50;opacity:0;pointer-events:none;
      background:#141a33;border:1px solid var(--border);border-radius:12px;padding:12px 22px;font-size:14px;
      transition:opacity .3s,transform .3s;box-shadow:0 16px 50px rgba(0,0,0,.5)}
    #toast.show{opacity:1;transform:translate(-50%,0)}
    @keyframes grad-slide{0%,100%{background-position:0% 0}50%{background-position:100% 0}}
    @keyframes sheen{0%,55%{transform:translateX(-120%)}85%,100%{transform:translateX(120%)}}
    @keyframes bob{0%,100%{transform:translate(-50%,0)}50%{transform:translate(-50%,10px)}}
    @keyframes pulse-glow{0%,100%{box-shadow:0 0 0 0 rgba(124,231,245,.25)}50%{box-shadow:0 0 24px 2px rgba(124,231,245,.25)}}
    @keyframes spin{to{transform:rotate(360deg)}}
    @media (prefers-reduced-motion: reduce){
      .reveal{opacity:1;transform:none;transition:none}
      h1 .grad,.btn.primary::after,.mouse i,.founder-photo::before,.eyebrow,nav{animation:none}
    }
    /* mobile: the capsule nav compacts; the GitHub link drops out so the
       essentials (logo · Toolkit · Changelog · Download CTA) always fit */
    @media (max-width:560px){
      nav{gap:6px;padding:7px 8px 7px 12px}
      nav .logo img{width:22px;height:22px}
      nav .logo{font-size:13.5px}
      nav .links a{font-size:12px;padding:6px 9px}
      nav .nav-github{display:none}
    }
    @media (max-width:640px){
      .wrap{padding:0 18px}
      .ctas .btn{padding:13px 22px;font-size:14px}
    }
    /* founder card: stack + centre everything on narrow screens */
    @media (max-width:760px){
      .founder-card{flex-direction:column;text-align:center;padding:30px 24px}
      .founder-photo{margin:0 auto}
      .founder blockquote{margin:0 auto}
    }
  </style>
</head>
<body>
  <canvas id="sky"></canvas>
  <div class="veil"></div>
  <div id="cursor" aria-hidden="true"><span class="ring"></span><span class="planet"></span></div>

  <nav>
    <a class="logo" href={`${base}/`}><img src={`${base}/logo.svg`} alt="" />Claude&nbsp;Galaxy</a>
    <div class="links">
      <a href={`${base}/toolkit`}>Toolkit</a>
      <a href={`${base}/changelog`}>Changelog</a>
      <a class="nav-github" href="https://github.com/Dontag/claude-toolkit" target="_blank" rel="noopener noreferrer" aria-label="GitHub">GitHub ↗</a>
      <a class="cta" href={`${base}/download`}>Download</a>
    </div>
  </nav>

  <section class="hero">
    <div class="hero-inner wrap" data-parallax="0.18">
      <img class="hero-mark reveal in" src={`${base}/logo.svg`} alt="Claude Galaxy" />
      <span class="eyebrow reveal in">A living universe for Claude Code</span>
      <h1>Your Claude setup,<br /><span class="grad">alive in a galaxy.</span></h1>
      <p class="sub">
        Skills, agents, hooks and commands grow as fruit on a 3D tree that watches your
        <code>.claude</code> folder in real time. Share your best work to a shared galaxy —
        one solar system per creator, orbiting a black hole.
      </p>
      <div class="ctas">
        <a class="btn primary" href={`${base}/app/`} target="_blank" rel="noopener noreferrer">🌌 Explore online <span style="opacity:.7;font-weight:500;font-size:12px">limited</span></a>
        <button class="btn ghost" id="downloadBtn">⬇ Download the desktop app</button>
      </div>
    </div>
    <div class="scroll-hint"><span class="mouse"><i></i></span><span class="chev"></span><span class="txt">scroll</span></div>
  </section>

  <section class="story">
    <div class="wrap">
      <div class="kicker reveal">Why this exists</div>
      <h2 class="reveal">Claude setups are invisible.<br />Yours should be a place.</h2>
      <p class="lead reveal" data-delay="1">
        Your skills and agents are just markdown files in a hidden folder. You forget what you have,
        you can't see it grow, and sharing means pasting files in chat. Claude Galaxy turns that
        folder into a world you can see, tend, and share.
      </p>
      <div class="cards">
        <div class="card reveal tilt" data-delay="1">
          <span class="glowline"></span>
          <div class="ico">🌱</div>
          <h3>A tree that grows with you</h3>
          <p>Every skill, agent, command and hook is a glowing fruit. Add a file — a fruit grows in.
             Delete one — it falls with physics. Over 10 in a category? A new branch grows automatically.</p>
        </div>
        <div class="card reveal tilt" data-delay="2">
          <span class="glowline"></span>
          <div class="ico">🌌</div>
          <h3>A galaxy of creators</h3>
          <p>Share any item with one toggle. Every user is a solar system — planets grouped in orbital
             lanes by kind, dust swirling around each one, comets streaking when the community works.</p>
        </div>
        <div class="card reveal tilt" data-delay="3">
          <span class="glowline"></span>
          <div class="ico">🔐</div>
          <h3>Editing with guardrails</h3>
          <p>Others request changes; you grant an exclusive 30-minute window. Their edit arrives as a
             proposal you approve or reject — nothing replaces your work without your yes.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="stats">
    <div class="wrap">
      <div class="kicker reveal" style="text-align:center;margin-bottom:26px">The starter pack, included</div>
      <div class="stats-grid">
        <div class="stat reveal"><b data-count="10">0</b><span>Skills</span></div>
        <div class="stat reveal" data-delay="1"><b data-count="9">0</b><span>Agents</span></div>
        <div class="stat reveal" data-delay="2"><b data-count="5">0</b><span>Commands</span></div>
        <div class="stat reveal" data-delay="3"><b data-count="3">0</b><span>Hooks</span></div>
